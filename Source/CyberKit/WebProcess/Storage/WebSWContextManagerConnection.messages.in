#if ENABLE(SERVICE_WORKER)

messages -> WebSWContextManagerConnection {
    InstallServiceWorker(struct CyberCore::ServiceWorkerContextData contextData, struct CyberCore::ServiceWorkerData workerData, String userAgent, enum:bool CyberCore::WorkerThreadMode workerThreadMode)
    UpdateAppInitiatedValue(CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, enum:bool CyberCore::LastNavigationWasAppInitiated lastNavigationWasAppInitiated)
    StartFetch(CyberCore::SWServerConnectionIdentifier serverConnectionIdentifier, CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, CyberCore::FetchIdentifier fetchIdentifier, CyberCore::ResourceRequest request, struct CyberCore::FetchOptions options, IPC::FormDataReference requestBody, String referrer, bool isServiceWorkerNavigationPreloadEnabled, String clientIdentifier, String resutlingClientIdentifier)
    CancelFetch(CyberCore::SWServerConnectionIdentifier serverConnectionIdentifier, CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, CyberCore::FetchIdentifier fetchIdentifier)
    ContinueDidReceiveFetchResponse(CyberCore::SWServerConnectionIdentifier serverConnectionIdentifier, CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, CyberCore::FetchIdentifier fetchIdentifier)
    PostMessageToServiceWorker(CyberCore::ServiceWorkerIdentifier destinationIdentifier, struct CyberCore::MessageWithMessagePorts message, CyberCore::ServiceWorkerOrClientData sourceData)
    FireInstallEvent(CyberCore::ServiceWorkerIdentifier identifier)
    FireActivateEvent(CyberCore::ServiceWorkerIdentifier identifier)
    FirePushEvent(CyberCore::ServiceWorkerIdentifier identifier, std::optional<IPC::DataReference> data) -> (bool result)
    FireNotificationEvent(CyberCore::ServiceWorkerIdentifier identifier, struct CyberCore::NotificationData data, enum:bool CyberCore::NotificationEventType type) -> (bool result)
    FireBackgroundFetchEvent(CyberCore::ServiceWorkerIdentifier identifier, struct CyberCore::BackgroundFetchInformation info) -> (bool result)
    FireBackgroundFetchClickEvent(CyberCore::ServiceWorkerIdentifier identifier, struct CyberCore::BackgroundFetchInformation info) -> (bool result)

    TerminateWorker(CyberCore::ServiceWorkerIdentifier identifier)
#if ENABLE(SHAREABLE_RESOURCE) && PLATFORM(COCOA)
    DidSaveScriptsToDisk(CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, CyberCore::ScriptBuffer script, HashMap<URL, CyberCore::ScriptBuffer> importedScripts);
#endif
    MatchAllCompleted(uint64_t matchAllRequestIdentifier, Vector<CyberCore::ServiceWorkerClientData> clientsData)
    SkipWaitingCompleted(uint64_t matchAllRequestIdentifier)
    SetUserAgent(String userAgent)
    UpdatePreferencesStore(struct CyberKit::WebPreferencesStore store)
    Close()
    SetThrottleState(bool isThrottleable)

    ConvertFetchToDownload(CyberCore::SWServerConnectionIdentifier serverConnectionIdentifier, CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, CyberCore::FetchIdentifier identifier)

    NavigationPreloadIsReady(CyberCore::SWServerConnectionIdentifier serverConnectionIdentifier, CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, CyberCore::FetchIdentifier identifier, CyberCore::ResourceResponse response)
    NavigationPreloadFailed(CyberCore::SWServerConnectionIdentifier serverConnectionIdentifier, CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, CyberCore::FetchIdentifier identifier, CyberCore::ResourceError error)
}

#endif
