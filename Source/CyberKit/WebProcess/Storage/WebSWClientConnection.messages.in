#if ENABLE(SERVICE_WORKER)

messages -> WebSWClientConnection {
    # When possible, these messages can be implemented directly by CyberCore::SWServer::Connection
    JobRejectedInServer(CyberCore::ServiceWorkerJobIdentifier jobDataIdentifier, struct CyberCore::ExceptionData exception)
    RegistrationJobResolvedInServer(CyberCore::ServiceWorkerJobIdentifier jobDataIdentifier, struct CyberCore::ServiceWorkerRegistrationData registration, enum:bool CyberCore::ShouldNotifyWhenResolved shouldNotifyWhenResolved)
    StartScriptFetchForServer(CyberCore::ServiceWorkerJobIdentifier jobDataIdentifier, CyberCore::ServiceWorkerRegistrationKey registrationKey, enum:uint8_t CyberCore::FetchOptions::Cache cachePolicy)
    UpdateRegistrationState(CyberCore::ServiceWorkerRegistrationIdentifier identifier, enum:uint8_t CyberCore::ServiceWorkerRegistrationState state, std::optional<CyberCore::ServiceWorkerData> serviceWorkerIdentifier)
    UpdateWorkerState(CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, enum:uint8_t CyberCore::ServiceWorkerState state)
    FireUpdateFoundEvent(CyberCore::ServiceWorkerRegistrationIdentifier identifier)
    SetRegistrationLastUpdateTime(CyberCore::ServiceWorkerRegistrationIdentifier identifier, WallTime lastUpdateTime)
    SetRegistrationUpdateViaCache(CyberCore::ServiceWorkerRegistrationIdentifier identifier, enum:uint8_t CyberCore::ServiceWorkerUpdateViaCache updateViaCache)
    NotifyClientsOfControllerChange(HashSet<CyberCore::ScriptExecutionContextIdentifier> contextIdentifiers, struct CyberCore::ServiceWorkerData newController)
    UpdateBackgroundFetchRegistration(struct CyberCore::BackgroundFetchInformation information)

    SetSWOriginTableIsImported()
    SetSWOriginTableSharedMemory(CyberKit::SharedMemory::Handle handle)
    PostMessageToServiceWorkerClient(CyberCore::ScriptExecutionContextIdentifier destinationContextIdentifier, struct CyberCore::MessageWithMessagePorts message, struct CyberCore::ServiceWorkerData source, String sourceOrigin)

    SetServiceWorkerClientIsControlled(CyberCore::ScriptExecutionContextIdentifier workerIdentifier, struct CyberCore::ServiceWorkerRegistrationData data) -> (bool isSuccess)

    FocusServiceWorkerClient(CyberCore::ScriptExecutionContextIdentifier clientIdentifier) -> (std::optional<CyberCore::ServiceWorkerClientData> result)

    NotifyRecordResponseBodyChunk(CyberKit::RetrieveRecordResponseBodyCallbackIdentifier identifier, IPC::SharedBufferReference data);
    NotifyRecordResponseBodyEnd(CyberKit::RetrieveRecordResponseBodyCallbackIdentifier identifier, CyberCore::ResourceError error);
}

#endif // ENABLE(SERVICE_WORKER)
