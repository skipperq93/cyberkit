#if ENABLE(SERVICE_WORKER)

messages -> WebSWClientConnection {
    # When possible, these messages can be implemented directly by CyberCore::SWServer::Connection
    JobRejectedInServer(CyberCore::ServiceWorkerJobIdentifier jobDataIdentifier, struct CyberCore::ExceptionData exception)
    RegistrationJobResolvedInServer(CyberCore::ServiceWorkerJobIdentifier jobDataIdentifier, struct CyberCore::ServiceWorkerRegistrationData registration, enum:bool CyberCore::ShouldNotifyWhenResolved shouldNotifyWhenResolved)
    StartScriptFetchForServer(CyberCore::ServiceWorkerJobIdentifier jobDataIdentifier, CyberCore::ServiceWorkerRegistrationKey registrationKey, CyberCore::FetchOptions::Cache cachePolicy)
    UpdateRegistrationState(CyberCore::ServiceWorkerRegistrationIdentifier identifier, enum:uint8_t CyberCore::ServiceWorkerRegistrationState state, Optional<CyberCore::ServiceWorkerData> serviceWorkerIdentifier)
    UpdateWorkerState(CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, enum:uint8_t CyberCore::ServiceWorkerState state)
    FireUpdateFoundEvent(CyberCore::ServiceWorkerRegistrationIdentifier identifier)
    SetRegistrationLastUpdateTime(CyberCore::ServiceWorkerRegistrationIdentifier identifier, WallTime lastUpdateTime)
    SetRegistrationUpdateViaCache(CyberCore::ServiceWorkerRegistrationIdentifier identifier, enum:uint8_t CyberCore::ServiceWorkerUpdateViaCache updateViaCache);
    NotifyClientsOfControllerChange(HashSet<CyberCore::DocumentIdentifier> contextIdentifiers, struct CyberCore::ServiceWorkerData newController)

    SetSWOriginTableIsImported()
    SetSWOriginTableSharedMemory(CyberKit::SharedMemory::IPCHandle handle)
    PostMessageToServiceWorkerClient(CyberCore::DocumentIdentifier destinationContextIdentifier, struct CyberCore::MessageWithMessagePorts message, struct CyberCore::ServiceWorkerData source, String sourceOrigin)

    DidMatchRegistration(uint64_t matchRequestIdentifier, Optional<CyberCore::ServiceWorkerRegistrationData> data)
    DidGetRegistrations(uint64_t matchRequestIdentifier, Vector<CyberCore::ServiceWorkerRegistrationData> registrations)
    RegistrationReady(uint64_t registrationReadyRequestIdentifier, struct CyberCore::ServiceWorkerRegistrationData data)

    SetDocumentIsControlled(CyberCore::DocumentIdentifier temporaryDocumentIdentifier, struct CyberCore::ServiceWorkerRegistrationData data) -> (bool isSuccess) Async
}

#endif // ENABLE(SERVICE_WORKER)
