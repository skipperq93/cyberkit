#if ENABLE(GPU_PROCESS)

messages -> MediaPlayerPrivateRemote NotRefCounted {
    NetworkStateChanged(struct CyberKit::RemoteMediaPlayerState state)
    ReadyStateChanged(struct CyberKit::RemoteMediaPlayerState state)
    FirstVideoFrameAvailable()
    VolumeChanged(double volume)
    MuteChanged(bool mute)
    TimeChanged(struct CyberKit::RemoteMediaPlayerState state)
    DurationChanged(struct CyberKit::RemoteMediaPlayerState state)
    RateChanged(double rate)
    PlaybackStateChanged(bool paused)
    EngineFailedToLoad(int platformErrorCode)
    UpdateCachedState(struct CyberKit::RemoteMediaPlayerState state)
    CharacteristicChanged(struct CyberKit::RemoteMediaPlayerState state)
    SizeChanged(CyberCore::FloatSize naturalSize)

    AddRemoteAudioTrack(CyberKit::TrackPrivateRemoteIdentifier trackID, struct CyberKit::TrackPrivateRemoteConfiguration configuration)
    RemoveRemoteAudioTrack(CyberKit::TrackPrivateRemoteIdentifier trackID)
    RemoteAudioTrackConfigurationChanged(CyberKit::TrackPrivateRemoteIdentifier trackID, struct CyberKit::TrackPrivateRemoteConfiguration configuration)

    AddRemoteTextTrack(CyberKit::TrackPrivateRemoteIdentifier trackID, struct CyberKit::TextTrackPrivateRemoteConfiguration configuration)
    RemoveRemoteTextTrack(CyberKit::TrackPrivateRemoteIdentifier trackID)
    RemoteTextTrackConfigurationChanged(CyberKit::TrackPrivateRemoteIdentifier trackID, struct CyberKit::TextTrackPrivateRemoteConfiguration configuration)

    ParseWebVTTFileHeader(CyberKit::TrackPrivateRemoteIdentifier trackID, String header)
    ParseWebVTTCueData(CyberKit::TrackPrivateRemoteIdentifier trackID, IPC::DataReference data)
    ParseWebVTTCueDataStruct(CyberKit::TrackPrivateRemoteIdentifier trackID, CyberCore::ISOWebVTTCue cueData)

    AddDataCue(CyberKit::TrackPrivateRemoteIdentifier trackID, MediaTime start, MediaTime end, IPC::DataReference data)
#if ENABLE(DATACUE_VALUE)
    AddDataCueWithType(CyberKit::TrackPrivateRemoteIdentifier trackID, MediaTime start, MediaTime end, CyberCore::SerializedPlatformDataCueValue cueData, String type)
    UpdateDataCue(CyberKit::TrackPrivateRemoteIdentifier trackID, MediaTime start, MediaTime end, CyberCore::SerializedPlatformDataCueValue cueData)
    RemoveDataCue(CyberKit::TrackPrivateRemoteIdentifier trackID, MediaTime start, MediaTime end, CyberCore::SerializedPlatformDataCueValue cueData)
#endif

    AddGenericCue(CyberKit::TrackPrivateRemoteIdentifier trackID, struct CyberCore::GenericCueData cue)
    UpdateGenericCue(CyberKit::TrackPrivateRemoteIdentifier trackID, struct CyberCore::GenericCueData cue)
    RemoveGenericCue(CyberKit::TrackPrivateRemoteIdentifier trackID, struct CyberCore::GenericCueData cue)

    AddRemoteVideoTrack(CyberKit::TrackPrivateRemoteIdentifier trackID, struct CyberKit::TrackPrivateRemoteConfiguration configuration)
    RemoveRemoteVideoTrack(CyberKit::TrackPrivateRemoteIdentifier trackID)
    RemoteVideoTrackConfigurationChanged(CyberKit::TrackPrivateRemoteIdentifier trackID, struct CyberKit::TrackPrivateRemoteConfiguration configuration)

    RequestResource(CyberKit::RemoteMediaResourceIdentifier remoteMediaResourceIdentifier, CyberCore::ResourceRequest request, enum:uint8_t CyberCore::PlatformMediaResourceLoader::LoadOptions options) -> () Async
    RemoveResource(CyberKit::RemoteMediaResourceIdentifier remoteMediaResourceIdentifier)
    SendH2Ping(URL url) -> (Expected<Seconds, CyberCore::ResourceError> result) Async
    ResourceNotSupported()

    EngineUpdated()

    ActiveSourceBuffersChanged()

#if ENABLE(ENCRYPTED_MEDIA)
    WaitingForKeyChanged()
    InitializationDataEncountered(String initDataType, IPC::DataReference initData)
#endif

#if ENABLE(LEGACY_ENCRYPTED_MEDIA)
    MediaPlayerKeyNeeded(IPC::DataReference message)
#endif

#if ENABLE(WIRELESS_PLAYBACK_TARGET)
    CurrentPlaybackTargetIsWirelessChanged(bool isCurrentPlaybackTargetWireless)
#endif
}

#endif
