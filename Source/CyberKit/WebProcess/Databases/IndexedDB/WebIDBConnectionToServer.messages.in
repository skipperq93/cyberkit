messages -> WebIDBConnectionToServer {
    DidDeleteDatabase(CyberCore::IDBResultData result)
    DidOpenDatabase(CyberCore::IDBResultData result)
    DidAbortTransaction(CyberCore::IDBResourceIdentifier transactionIdentifier, CyberCore::IDBError error)
    DidCommitTransaction(CyberCore::IDBResourceIdentifier transactionIdentifier, CyberCore::IDBError error)
    DidCreateObjectStore(CyberCore::IDBResultData result)
    DidDeleteObjectStore(CyberCore::IDBResultData result)
    DidRenameObjectStore(CyberCore::IDBResultData result)
    DidClearObjectStore(CyberCore::IDBResultData result)
    DidCreateIndex(CyberCore::IDBResultData result)
    DidDeleteIndex(CyberCore::IDBResultData result)
    DidRenameIndex(CyberCore::IDBResultData result)
    DidPutOrAdd(CyberCore::IDBResultData result)
    DidGetRecord(CyberKit::WebIDBResult result)
    DidGetAllRecords(CyberKit::WebIDBResult result)
    DidGetCount(CyberCore::IDBResultData result)
    DidDeleteRecord(CyberCore::IDBResultData result)
    DidOpenCursor(CyberKit::WebIDBResult result)
    DidIterateCursor(CyberKit::WebIDBResult result)

    FireVersionChangeEvent(uint64_t databaseConnectionIdentifier, CyberCore::IDBResourceIdentifier requestIdentifier, uint64_t requestedVersion)
    DidStartTransaction(CyberCore::IDBResourceIdentifier transactionIdentifier, CyberCore::IDBError error)
    DidCloseFromServer(uint64_t databaseConnectionIdentifier, CyberCore::IDBError error) final;
    NotifyOpenDBRequestBlocked(CyberCore::IDBResourceIdentifier requestIdentifier, uint64_t oldVersion, uint64_t newVersion)

    DidGetAllDatabaseNamesAndVersions(CyberCore::IDBResourceIdentifier requestIdentifier, Vector<CyberCore::IDBDatabaseNameAndVersion> databases)
}
