messages -> WebProcess LegacyReceiver NotRefCounted {
    InitializeWebProcess(struct CyberKit::WebProcessCreationParameters processCreationParameters)
    SetWebsiteDataStoreParameters(struct CyberKit::WebProcessDataStoreParameters parameters)

    CreateWebPage(CyberCore::PageIdentifier newPageID, struct CyberKit::WebPageCreationParameters pageCreationParameters)

    PrewarmWithDomainInformation(struct CyberCore::PrewarmInformation prewarmInformation)

    # Global preferences.
    SetCacheModel(enum:uint8_t CyberKit::CacheModel cacheModel)

    RegisterURLSchemeAsEmptyDocument(String scheme)
    RegisterURLSchemeAsSecure(String scheme)
    RegisterURLSchemeAsBypassingContentSecurityPolicy(String scheme)
    SetDomainRelaxationForbiddenForURLScheme(String scheme)
    RegisterURLSchemeAsLocal(String scheme)
    RegisterURLSchemeAsNoAccess(String scheme)
    RegisterURLSchemeAsDisplayIsolated(String scheme)
    RegisterURLSchemeAsCORSEnabled(String scheme)
    RegisterURLSchemeAsCachePartitioned(String scheme)
    RegisterURLSchemeAsCanDisplayOnlyIfCanRequest(String scheme)

    SetDefaultRequestTimeoutInterval(double timeoutInterval)
    SetAlwaysUsesComplexTextCodePath(bool alwaysUseComplexText)
    SetDisableFontSubpixelAntialiasingForTesting(bool disable)
    SetTrackingPreventionEnabled(bool enabled);
    ClearResourceLoadStatistics();
    UserPreferredLanguagesChanged(Vector<String> languages)
    FullKeyboardAccessModeChanged(bool fullKeyboardAccessEnabled)

#if HAVE(MOUSE_DEVICE_OBSERVATION)
    SetHasMouseDevice(bool hasMouseDevice)
#endif

#if HAVE(STYLUS_DEVICE_OBSERVATION)
    SetHasStylusDevice(bool hasStylusDevice)
#endif

    void StartMemorySampler(CyberKit::SandboxExtension::Handle sampleLogFileHandle, String sampleLogFilePath, double interval);
    void StopMemorySampler();

    SetTextCheckerState(struct CyberKit::TextCheckerState textCheckerState)

    SetEnhancedAccessibility(bool flag)

    GarbageCollectJavaScriptObjects()
    SetJavaScriptGarbageCollectorTimerEnabled(bool enable)

    SetInjectedBundleParameter(String parameter, IPC::DataReference value);
    SetInjectedBundleParameters(IPC::DataReference parameters);
    HandleInjectedBundleMessage(String messageName, CyberKit::UserData messageBody);

    FetchWebsiteData(OptionSet<CyberKit::WebsiteDataType> websiteDataTypes) -> (struct CyberKit::WebsiteData websiteData)
    DeleteWebsiteData(OptionSet<CyberKit::WebsiteDataType> websiteDataTypes, WallTime modifiedSince) -> ()
    DeleteWebsiteDataForOrigins(OptionSet<CyberKit::WebsiteDataType> websiteDataTypes, Vector<CyberCore::SecurityOriginData> origins) -> ()
    DeleteWebsiteDataForOrigin(OptionSet<CyberKit::WebsiteDataType> websiteDataTypes, struct CyberCore::ClientOrigin origin) -> ()
    ReloadExecutionContextsForOrigin(struct CyberCore::ClientOrigin origin, std::optional<CyberCore::FrameIdentifier> triggeringFrame) -> ()
    DeleteAllCookies() -> ()

    SetHiddenPageDOMTimerThrottlingIncreaseLimit(int milliseconds)

    SetMemoryCacheDisabled(bool disabled);

#if ENABLE(SERVICE_CONTROLS)
    SetEnabledServices(bool hasImageServices, bool hasSelectionServices, bool hasRichContentServices)
#endif

    EnsureAutomationSessionProxy(String sessionIdentifier)
    DestroyAutomationSessionProxy()

    PrepareToSuspend(bool isSuspensionImminent, MonotonicTime estimatedSuspendTime) -> ()
    ProcessDidResume()

    BackgroundResponsivenessPing()

#if ENABLE(GAMEPAD)
    SetInitialGamepads(Vector<std::optional<CyberKit::GamepadData>> gamepadDatas)
    GamepadConnected(CyberKit::GamepadData gamepadData, enum:bool CyberCore::EventMakesGamepadsVisible eventVisibility)
    GamepadDisconnected(unsigned index)
#endif

    EstablishRemoteWorkerContextConnectionToNetworkProcess(enum:bool CyberKit::RemoteWorkerType workerType, CyberKit::PageGroupIdentifier pageGroupID, CyberKit::WebPageProxyIdentifier webPageProxyID, CyberCore::PageIdentifier pageID, struct CyberKit::WebPreferencesStore store, CyberCore::RegistrableDomain domain, std::optional<CyberCore::ScriptExecutionContextIdentifier> serviceWorkerPageIdentifier, struct CyberKit::RemoteWorkerInitializationData initializationData) -> ()

    SetHasSuspendedPageProxy(bool hasSuspendedPageProxy);
    SetIsInProcessCache(bool isInProcessCache)
    MarkIsNoLongerPrewarmed()
    GetActivePagesOriginsForTesting() -> (Vector<String> activeOrigins)

#if PLATFORM(COCOA)
    SetScreenProperties(struct CyberCore::ScreenProperties screenProperties)
#endif
#if PLATFORM(MAC)
    ScrollerStylePreferenceChanged(bool useOvelayScrollbars)
    DisplayConfigurationChanged(CGDirectDisplayID displayID, CGDisplayChangeSummaryFlags flags)
#endif

#if PLATFORM(IOS_FAMILY)
    UserInterfaceIdiomDidChange(bool isPhoneOrWatch)
#endif

#if PLATFORM(IOS_FAMILY) && !PLATFORM(MACCATALYST)
    BacklightLevelDidChange(float backlightLevel)
#endif

#if PLATFORM(MAC) || PLATFORM(MACCATALYST)
    ColorPreferencesDidChange()
#endif

    IsJITEnabled() -> (bool enabled)

#if PLATFORM(COCOA)
    SetMediaMIMETypes(Vector<String> types)
#if ENABLE(REMOTE_INSPECTOR)
    EnableRemoteWebInspector();
#endif
#endif

#if ENABLE(MEDIA_STREAM)
    AddMockMediaDevice(struct CyberCore::MockMediaDevice device);
    ClearMockMediaDevices();
    RemoveMockMediaDevice(String persistentId);
    SetMockMediaDeviceIsEphemeral(String persistentId, bool isEphemeral);
    ResetMockMediaDevices();

#if ENABLE(SANDBOX_EXTENSIONS)
    GrantUserMediaDeviceSandboxExtensions(CyberKit::MediaDeviceSandboxExtensions sandboxExtensions)
    RevokeUserMediaDeviceSandboxExtensions(Vector<String> sandboxExtensionIDs)
#endif
#endif

    ClearCurrentModifierStateForTesting()

    SetBackForwardCacheCapacity(unsigned capacity);
    ClearCachedPage(CyberCore::BackForwardItemIdentifier backForwardItemID) -> ()

#if PLATFORM(GTK) || PLATFORM(WPE)
    SendMessageToWebProcessExtension(struct CyberKit::UserMessage userMessage)
#endif

#if ENABLE(TRACKING_PREVENTION)
    SeedResourceLoadStatisticsForTesting(CyberCore::RegistrableDomain firstPartyDomain, CyberCore::RegistrableDomain thirdPartyDomain, bool shouldScheduleNotification) -> ()
    SetThirdPartyCookieBlockingMode(enum:uint8_t CyberCore::ThirdPartyCookieBlockingMode blockingMode) -> ()
    SetDomainsWithUserInteraction(HashSet<CyberCore::RegistrableDomain> domains)
    SetDomainsWithCrossPageStorageAccess(HashMap<CyberCore::RegistrableDomain, CyberCore::RegistrableDomain> domains) -> ()
    SendResourceLoadStatisticsDataImmediately() -> ()
#endif

    GrantAccessToAssetServices(Vector<CyberKit::SandboxExtension::Handle> assetServicesHandles)
    RevokeAccessToAssetServices()
    SwitchFromStaticFontRegistryToUserFontRegistry(Vector<CyberKit::SandboxExtension::Handle> fontMachExtensionHandles)

#if PLATFORM(COCOA)
    DisableURLSchemeCheckInDataDetectors()
    UnblockServicesRequiredByAccessibility(Vector<CyberKit::SandboxExtension::Handle> handleArray)
#if ENABLE(CFPREFS_DIRECT_MODE)
    NotifyPreferencesChanged(String domain, String key, std::optional<String> encodedValue)
#endif
    PowerSourceDidChange(bool hasAC)
#endif

#if PLATFORM(GTK) && !USE(GTK4)
    SetUseSystemAppearanceForScrollbars(bool useSystemAppearanceForScrollbars)
#endif

#if PLATFORM(COCOA)
    DidWriteToPasteboardAsynchronously(String pasteboardName);
#endif

#if HAVE(CVDISPLAYLINK)
    DisplayDidRefresh(uint32_t displayID, struct CyberCore::DisplayUpdate update)
#endif

#if PLATFORM(MAC)
    SystemWillPowerOn()
    SystemWillSleep()
    SystemDidWake()
#endif

#if HAVE(AUDIO_COMPONENT_SERVER_REGISTRATIONS)
    ConsumeAudioComponentRegistrations(IPC::SharedBufferReference registrationData)
#endif

#if PLATFORM(COCOA)
    AccessibilityPreferencesDidChange(struct CyberKit::AccessibilityPreferences accessibilityPreferences)
#endif

#if HAVE(MEDIA_ACCESSIBILITY_FRAMEWORK)
    SetMediaAccessibilityPreferences(CyberCore::CaptionUserPreferences::CaptionDisplayMode displayMode, Vector<String> languages)
#endif

#if PLATFORM(MAC)
    OpenDirectoryCacheInvalidated(CyberKit::SandboxExtension::Handle handle, CyberKit::SandboxExtension::Handle machBootstrapHandle)
#endif
}
