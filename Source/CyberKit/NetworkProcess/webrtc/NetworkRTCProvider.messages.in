#if USE(LIBWEBRTC)

messages -> NetworkRTCProvider {
    CreateUDPSocket(CyberCore::LibWebRTCSocketIdentifier identifier, CyberKit::RTCNetwork::SocketAddress localAddress, uint16_t minPort, uint16_t maxPort)
    CreateServerTCPSocket(CyberCore::LibWebRTCSocketIdentifier identifier, CyberKit::RTCNetwork::SocketAddress localAddress, uint16_t minPort, uint16_t maxPort, int options)
    CreateClientTCPSocket(CyberCore::LibWebRTCSocketIdentifier identifier, CyberKit::RTCNetwork::SocketAddress localAddress, CyberKit::RTCNetwork::SocketAddress remoteAddress, String userAgent, int options)
    WrapNewTCPConnection(CyberCore::LibWebRTCSocketIdentifier identifier, CyberCore::LibWebRTCSocketIdentifier newConnectionSocketIdentifier)

    CreateResolver(CyberKit::LibWebRTCResolverIdentifier identifier, String address)
    StopResolver(CyberKit::LibWebRTCResolverIdentifier identifier)

    void SendToSocket(CyberCore::LibWebRTCSocketIdentifier identifier, IPC::DataReference data, CyberKit::RTCNetwork::SocketAddress address, struct CyberKit::RTCPacketOptions options)
    void CloseSocket(CyberCore::LibWebRTCSocketIdentifier identifier)
    void SetSocketOption(CyberCore::LibWebRTCSocketIdentifier identifier, int option, int value)
}

#endif // USE(LIBWEBRTC)
