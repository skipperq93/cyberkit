 messages -> NetworkStorageManager {
    Persisted(struct CyberCore::ClientOrigin origin) -> (bool persisted)
    Persist(struct CyberCore::ClientOrigin origin) -> (bool persisted)
    Estimate(struct CyberCore::ClientOrigin origin) -> (std::optional<CyberCore::StorageEstimate> result);
    FileSystemGetDirectory(struct CyberCore::ClientOrigin origin) -> (Expected<CyberCore::FileSystemHandleIdentifier, CyberKit::FileSystemStorageError> result)
    CloseHandle(CyberCore::FileSystemHandleIdentifier identifier)
    IsSameEntry(CyberCore::FileSystemHandleIdentifier identifier, CyberCore::FileSystemHandleIdentifier targetIdentifier) -> (bool result)
    GetFileHandle(CyberCore::FileSystemHandleIdentifier identifier, String name, bool createIfNecessary) -> (Expected<CyberCore::FileSystemHandleIdentifier, CyberKit::FileSystemStorageError> result)
    GetDirectoryHandle(CyberCore::FileSystemHandleIdentifier identifier, String name, bool createIfNecessary) -> (Expected<CyberCore::FileSystemHandleIdentifier, CyberKit::FileSystemStorageError> result)
    RemoveEntry(CyberCore::FileSystemHandleIdentifier identifier, String name, bool deleteRecursively) -> (std::optional<CyberKit::FileSystemStorageError> result)
    Resolve(CyberCore::FileSystemHandleIdentifier identifier, CyberCore::FileSystemHandleIdentifier targetIdentifier) -> (Expected<Vector<String>, CyberKit::FileSystemStorageError> result)
    Move(CyberCore::FileSystemHandleIdentifier identifier, CyberCore::FileSystemHandleIdentifier destinationIdentifier, String newName) -> (std::optional<CyberKit::FileSystemStorageError> result)
    GetFile(CyberCore::FileSystemHandleIdentifier identifier) -> (Expected<String, CyberKit::FileSystemStorageError> result)
    CreateSyncAccessHandle(CyberCore::FileSystemHandleIdentifier identifier) -> (Expected<CyberKit::FileSystemSyncAccessHandleInfo, CyberKit::FileSystemStorageError> result)
    CloseSyncAccessHandle(CyberCore::FileSystemHandleIdentifier identifier, CyberCore::FileSystemSyncAccessHandleIdentifier accessHandleIdentifier) -> ()
    RequestNewCapacityForSyncAccessHandle(CyberCore::FileSystemHandleIdentifier identifier, CyberCore::FileSystemSyncAccessHandleIdentifier accessHandleIdentifier, uint64_t newCapacity) -> (std::optional<uint64_t> result)
    GetHandleNames(CyberCore::FileSystemHandleIdentifier identifier) -> (Expected<Vector<String>, CyberKit::FileSystemStorageError> result)
    GetHandle(CyberCore::FileSystemHandleIdentifier identifier, String name) -> (Expected<std::pair<CyberCore::FileSystemHandleIdentifier, bool>, CyberKit::FileSystemStorageError> result)

    ConnectToStorageArea(CyberCore::StorageType type, CyberKit::StorageAreaMapIdentifier sourceIdentifier, std::optional<CyberKit::StorageNamespaceIdentifier> namespaceIdentifier, struct CyberCore::ClientOrigin origin) -> (CyberKit::StorageAreaIdentifier identifier, HashMap<String, String> items, uint64_t messageIdentifier)
    ConnectToStorageAreaSync(CyberCore::StorageType type, CyberKit::StorageAreaMapIdentifier sourceIdentifier, std::optional<CyberKit::StorageNamespaceIdentifier> namespaceIdentifier, struct CyberCore::ClientOrigin origin) -> (CyberKit::StorageAreaIdentifier identifier, HashMap<String, String> items, uint64_t messageIdentifier) Synchronous
    CancelConnectToStorageArea(CyberCore::StorageType type, std::optional<CyberKit::StorageNamespaceIdentifier> namespaceIdentifier, struct CyberCore::ClientOrigin origin)
    DisconnectFromStorageArea(CyberKit::StorageAreaIdentifier identifier)
    CloneSessionStorageNamespace(CyberKit::StorageNamespaceIdentifier fromStorageNamespaceID, CyberKit::StorageNamespaceIdentifier toStorageNamespaceID)
    SetItem(CyberKit::StorageAreaIdentifier identifier, CyberKit::StorageAreaImplIdentifier implIdentifier, String key, String value, String urlString) -> (bool hasError, HashMap<String, String> allItems)
    RemoveItem(CyberKit::StorageAreaIdentifier identifier, CyberKit::StorageAreaImplIdentifier implIdentifier, String key, String urlString) -> ()
    Clear(CyberKit::StorageAreaIdentifier identifier, CyberKit::StorageAreaImplIdentifier implIdentifier, String urlString) -> ()

    OpenDatabase(CyberCore::IDBRequestData requestData)
    OpenDBRequestCancelled(CyberCore::IDBRequestData requestData)
    DeleteDatabase(CyberCore::IDBRequestData requestData)
    EstablishTransaction(uint64_t databaseConnectionIdentifier, CyberCore::IDBTransactionInfo info)
    DatabaseConnectionPendingClose(uint64_t databaseConnectionIdentifier)
    DatabaseConnectionClosed(uint64_t databaseConnectionIdentifier)
    AbortOpenAndUpgradeNeeded(uint64_t databaseConnectionIdentifier, std::optional<CyberCore::IDBResourceIdentifier> transactionIdentifier)
    DidFireVersionChangeEvent(uint64_t databaseConnectionIdentifier, CyberCore::IDBResourceIdentifier requestIdentifier, CyberCore::IndexedDB::ConnectionClosedOnBehalfOfServer connectionClosedOnBehalfOfServer)
    DidFinishHandlingVersionChangeTransaction(uint64_t databaseConnectionIdentifier, CyberCore::IDBResourceIdentifier transactionIdentifier)
    AbortTransaction(CyberCore::IDBResourceIdentifier transactionIdentifier)
    CommitTransaction(CyberCore::IDBResourceIdentifier transactionIdentifier, uint64_t pendingRequestCount)
    CreateObjectStore(CyberCore::IDBRequestData requestData, CyberCore::IDBObjectStoreInfo info)
    DeleteObjectStore(CyberCore::IDBRequestData requestData, String objectStoreName)
    RenameObjectStore(CyberCore::IDBRequestData requestData, uint64_t objectStoreIdentifier, String newName)
    ClearObjectStore(CyberCore::IDBRequestData requestData, uint64_t objectStoreIdentifier)
    CreateIndex(CyberCore::IDBRequestData requestData, CyberCore::IDBIndexInfo info)
    DeleteIndex(CyberCore::IDBRequestData requestData, uint64_t objectStoreIdentifier, String indexName)
    RenameIndex(CyberCore::IDBRequestData requestData, uint64_t objectStoreIdentifier, uint64_t indexIdentifier, String newName)
    PutOrAdd(CyberCore::IDBRequestData requestData, CyberCore::IDBKeyData key, CyberCore::IDBValue value, CyberCore::IndexedDB::ObjectStoreOverwriteMode overwriteMode)
    GetRecord(CyberCore::IDBRequestData requestData, struct CyberCore::IDBGetRecordData getRecordData)
    GetAllRecords(CyberCore::IDBRequestData requestData, struct CyberCore::IDBGetAllRecordsData getAllRecordsData)
    GetCount(CyberCore::IDBRequestData requestData, struct CyberCore::IDBKeyRangeData range)
    DeleteRecord(CyberCore::IDBRequestData requestData, struct CyberCore::IDBKeyRangeData range)
    OpenCursor(CyberCore::IDBRequestData requestData, CyberCore::IDBCursorInfo info)
    IterateCursor(CyberCore::IDBRequestData requestData, struct CyberCore::IDBIterateCursorData data)
    GetAllDatabaseNamesAndVersions(CyberCore::IDBResourceIdentifier requestIdentifier, struct CyberCore::ClientOrigin origin)

    CacheStorageOpenCache(struct CyberCore::ClientOrigin origin, String cacheName) -> (CyberCore::DOMCacheEngine::CacheIdentifierOrError result)
    CacheStorageRemoveCache(CyberCore::DOMCacheIdentifier cacheIdentifier) -> (CyberCore::DOMCacheEngine::RemoveCacheIdentifierOrError result)
    CacheStorageAllCaches(struct CyberCore::ClientOrigin origin, uint64_t updateCounter) -> (CyberCore::DOMCacheEngine::CacheInfosOrError result)
    CacheStorageReference(CyberCore::DOMCacheIdentifier cacheIdentifier)
    CacheStorageDereference(CyberCore::DOMCacheIdentifier cacheIdentifier)
    CacheStorageRetrieveRecords(CyberCore::DOMCacheIdentifier cacheIdentifier, struct CyberCore::RetrieveRecordsOptions options) -> (CyberCore::DOMCacheEngine::CrossThreadRecordsOrError result)
    CacheStorageRemoveRecords(CyberCore::DOMCacheIdentifier cacheIdentifier, CyberCore::ResourceRequest request, struct CyberCore::CacheQueryOptions options) -> (CyberCore::DOMCacheEngine::RecordIdentifiersOrError result)
    CacheStoragePutRecords(CyberCore::DOMCacheIdentifier cacheIdentifier, Vector<CyberCore::DOMCacheEngine::CrossThreadRecord> records) -> (CyberCore::DOMCacheEngine::RecordIdentifiersOrError result)
    CacheStorageClearMemoryRepresentation(struct CyberCore::ClientOrigin origin) -> (std::optional<CyberCore::DOMCacheEngine::Error> error)
    CacheStorageRepresentation() -> (String representation)
}
