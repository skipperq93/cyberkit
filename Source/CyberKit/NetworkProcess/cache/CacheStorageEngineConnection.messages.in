messages -> CacheStorageEngineConnection {
    Reference(CyberCore::DOMCacheIdentifier cacheIdentifier)
    Dereference(CyberCore::DOMCacheIdentifier cacheIdentifier)

    Open(struct CyberCore::ClientOrigin origin, String cacheName) -> (CyberCore::DOMCacheEngine::CacheIdentifierOrError result)
    Remove(CyberCore::DOMCacheIdentifier cacheIdentifier) -> (CyberCore::DOMCacheEngine::RemoveCacheIdentifierOrError result)
    Caches(struct CyberCore::ClientOrigin origin, uint64_t updateCounter) -> (CyberCore::DOMCacheEngine::CacheInfosOrError result)

    RetrieveRecords(CyberCore::DOMCacheIdentifier cacheIdentifier, struct CyberCore::RetrieveRecordsOptions options) -> (CyberCore::DOMCacheEngine::RecordsOrError result)
    DeleteMatchingRecords(CyberCore::DOMCacheIdentifier cacheIdentifier, CyberCore::ResourceRequest request, struct CyberCore::CacheQueryOptions options) -> (CyberCore::DOMCacheEngine::RecordIdentifiersOrError result)
    PutRecords(CyberCore::DOMCacheIdentifier cacheIdentifier, Vector<CyberCore::DOMCacheEngine::Record> record) -> (CyberCore::DOMCacheEngine::RecordIdentifiersOrError result)

    ClearMemoryRepresentation(struct CyberCore::ClientOrigin origin) -> (std::optional<CyberCore::DOMCacheEngine::Error> error)
    EngineRepresentation() -> (String representation)
}
