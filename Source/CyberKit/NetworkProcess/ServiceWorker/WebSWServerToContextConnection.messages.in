#if ENABLE(SERVICE_WORKER)

messages -> WebSWServerToContextConnection NotRefCounted {
    # When possible, these messages can be implemented directly by CyberCore::SWServerToContextConnection

    ScriptContextFailedToStart(Optional<CyberCore::ServiceWorkerJobDataIdentifier> jobDataIdentifier, CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, String message)
    ScriptContextStarted(Optional<CyberCore::ServiceWorkerJobDataIdentifier> jobDataIdentifier, CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, bool doesHandleFetch)
    DidFinishInstall(Optional<CyberCore::ServiceWorkerJobDataIdentifier> jobDataIdentifier, CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, bool wasSuccessful)
    DidFinishActivation(CyberCore::ServiceWorkerIdentifier identifier)
    SetServiceWorkerHasPendingEvents(CyberCore::ServiceWorkerIdentifier identifier, bool hasPendingEvents)
    SkipWaiting(CyberCore::ServiceWorkerIdentifier identifier) -> () Async
    WorkerTerminated(CyberCore::ServiceWorkerIdentifier identifier)
    FindClientByIdentifier(uint64_t requestIdentifier, CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, struct CyberCore::ServiceWorkerClientIdentifier clientIdentifier)
    MatchAll(uint64_t matchAllRequestIdentifier, CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, struct CyberCore::ServiceWorkerClientQueryOptions options);
    Claim(CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier) -> (Optional<CyberCore::ExceptionData> result) Async
    SetScriptResource(CyberCore::ServiceWorkerIdentifier identifier, URL scriptURL, String script, URL responseURL, String mimeType)
    PostMessageToServiceWorkerClient(struct CyberCore::ServiceWorkerClientIdentifier destination, struct CyberCore::MessageWithMessagePorts message, CyberCore::ServiceWorkerIdentifier source, String sourceOrigin)
    DidFailHeartBeatCheck(CyberCore::ServiceWorkerIdentifier identifier)
}

#endif // ENABLE(SERVICE_WORKER)
