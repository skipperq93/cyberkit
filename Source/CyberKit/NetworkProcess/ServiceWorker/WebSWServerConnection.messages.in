#if ENABLE(SERVICE_WORKER)

messages -> WebSWServerConnection NotRefCounted {
    # When possible, these messages can be implemented directly by CyberCore::SWClientConnection
    ScheduleJobInServer(struct CyberCore::ServiceWorkerJobData jobData)
    FinishFetchingScriptInServer(struct CyberCore::ServiceWorkerFetchResult result)
    AddServiceWorkerRegistrationInServer(CyberCore::ServiceWorkerRegistrationIdentifier identifier)
    RemoveServiceWorkerRegistrationInServer(CyberCore::ServiceWorkerRegistrationIdentifier identifier)

    PostMessageToServiceWorker(CyberCore::ServiceWorkerIdentifier destination, struct CyberCore::MessageWithMessagePorts message, CyberCore::ServiceWorkerOrClientIdentifier source)

    DidResolveRegistrationPromise(CyberCore::ServiceWorkerRegistrationKey key)

    MatchRegistration(uint64_t serviceRegistrationMatchRequestIdentifier, struct CyberCore::SecurityOriginData topOrigin, URL clientURL)
    WhenRegistrationReady(uint64_t serviceRegistrationMatchRequestIdentifier, struct CyberCore::SecurityOriginData topOrigin, URL clientURL)
    GetRegistrations(uint64_t serviceRegistrationMatchRequestIdentifier, struct CyberCore::SecurityOriginData topOrigin, URL clientURL)
    RegisterServiceWorkerClient(struct CyberCore::SecurityOriginData topOrigin, struct CyberCore::ServiceWorkerClientData data, Optional<CyberCore::ServiceWorkerRegistrationIdentifier> controllingServiceWorkerRegistrationIdentifier, String userAgent)
    UnregisterServiceWorkerClient(struct CyberCore::ServiceWorkerClientIdentifier identifier)

    SyncTerminateWorkerFromClient(CyberCore::ServiceWorkerIdentifier workerIdentifier) -> () Synchronous

    SetThrottleState(bool isThrottleable)
    StoreRegistrationsOnDisk() -> () Async
    IsServiceWorkerRunning(CyberCore::ServiceWorkerIdentifier workerIdentifier) -> (bool isRunning) Async
}

#endif // ENABLE(SERVICE_WORKER)
