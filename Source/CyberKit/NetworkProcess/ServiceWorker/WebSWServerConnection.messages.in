#if ENABLE(SERVICE_WORKER)

messages -> WebSWServerConnection NotRefCounted {
    # When possible, these messages can be implemented directly by CyberCore::SWClientConnection
    ScheduleJobInServer(struct CyberCore::ServiceWorkerJobData jobData)
    ScheduleUnregisterJobInServer(CyberCore::ServiceWorkerJobIdentifier jobIdentifier, CyberCore::ServiceWorkerRegistrationIdentifier identifier, CyberCore::ServiceWorkerOrClientIdentifier documentIdentifier) -> (Expected<bool, CyberCore::ExceptionData> result)

    FinishFetchingScriptInServer(struct CyberCore::ServiceWorkerJobDataIdentifier jobDataIdentifier, CyberCore::ServiceWorkerRegistrationKey registrationKey, struct CyberCore::WorkerFetchResult result)
    AddServiceWorkerRegistrationInServer(CyberCore::ServiceWorkerRegistrationIdentifier identifier)
    RemoveServiceWorkerRegistrationInServer(CyberCore::ServiceWorkerRegistrationIdentifier identifier)

    PostMessageToServiceWorker(CyberCore::ServiceWorkerIdentifier destination, struct CyberCore::MessageWithMessagePorts message, CyberCore::ServiceWorkerOrClientIdentifier source)

    DidResolveRegistrationPromise(CyberCore::ServiceWorkerRegistrationKey key)

    MatchRegistration(CyberCore::SecurityOriginData topOrigin, URL clientURL) -> (std::optional<CyberCore::ServiceWorkerRegistrationData> registration)
    WhenRegistrationReady(CyberCore::SecurityOriginData topOrigin, URL clientURL) -> (std::optional<CyberCore::ServiceWorkerRegistrationData> registration)
    GetRegistrations(CyberCore::SecurityOriginData topOrigin, URL clientURL) -> (Vector<CyberCore::ServiceWorkerRegistrationData> registrations)
    RegisterServiceWorkerClient(struct CyberCore::ClientOrigin clientOrigin, struct CyberCore::ServiceWorkerClientData data, std::optional<CyberCore::ServiceWorkerRegistrationIdentifier> controllingServiceWorkerRegistrationIdentifier, String userAgent)
    UnregisterServiceWorkerClient(CyberCore::ScriptExecutionContextIdentifier identifier)

    TerminateWorkerFromClient(CyberCore::ServiceWorkerIdentifier workerIdentifier) -> ()
    WhenServiceWorkerIsTerminatedForTesting(CyberCore::ServiceWorkerIdentifier workerIdentifier) -> ()

    SetThrottleState(bool isThrottleable)
    StoreRegistrationsOnDisk() -> ()

    SubscribeToPushService(CyberCore::ServiceWorkerRegistrationIdentifier identifier, Vector<uint8_t> applicationServerKey) -> (Expected<CyberCore::PushSubscriptionData, CyberCore::ExceptionData> result)
    UnsubscribeFromPushService(CyberCore::ServiceWorkerRegistrationIdentifier serviceWorkerRegistrationIdentifier, CyberCore::PushSubscriptionIdentifier pushSubscriptionIdentifier) -> (Expected<bool, CyberCore::ExceptionData> result)
    GetPushSubscription(CyberCore::ServiceWorkerRegistrationIdentifier identifier) -> (Expected<std::optional<CyberCore::PushSubscriptionData>, CyberCore::ExceptionData> result)
    GetPushPermissionState(CyberCore::ServiceWorkerRegistrationIdentifier identifier) -> (Expected<uint8_t, CyberCore::ExceptionData> result) 

    EnableNavigationPreload(CyberCore::ServiceWorkerRegistrationIdentifier identifier) -> (std::optional<CyberCore::ExceptionData> result)
    DisableNavigationPreload(CyberCore::ServiceWorkerRegistrationIdentifier identifier) -> (std::optional<CyberCore::ExceptionData> result)
    SetNavigationPreloadHeaderValue(CyberCore::ServiceWorkerRegistrationIdentifier identifier, String value) -> (std::optional<CyberCore::ExceptionData> result)
    GetNavigationPreloadState(CyberCore::ServiceWorkerRegistrationIdentifier identifier) -> (Expected<CyberCore::NavigationPreloadState, CyberCore::ExceptionData> result)

    StartBackgroundFetch(CyberCore::ServiceWorkerRegistrationIdentifier registrationIdentifier, String backgroundFetchIdentifier, Vector<CyberCore::BackgroundFetchRequest> requests, struct CyberCore::BackgroundFetchOptions options) -> (Expected<CyberCore::BackgroundFetchInformation, CyberCore::ExceptionData> result)
    BackgroundFetchInformation(CyberCore::ServiceWorkerRegistrationIdentifier registrationIdentifier, String backgroundFetchIdentifier) -> (Expected<CyberCore::BackgroundFetchInformation, CyberCore::ExceptionData> result)
    BackgroundFetchIdentifiers(CyberCore::ServiceWorkerRegistrationIdentifier registrationIdentifier) -> (Vector<String> result)

    AbortBackgroundFetch(CyberCore::ServiceWorkerRegistrationIdentifier registrationIdentifier, String backgroundFetchIdentifier) -> (bool result)
    MatchBackgroundFetch(CyberCore::ServiceWorkerRegistrationIdentifier registrationIdentifier, String backgroundFetchIdentifier, struct CyberCore::RetrieveRecordsOptions options) -> (Vector<CyberCore::BackgroundFetchRecordInformation> results)
    RetrieveRecordResponse(CyberCore::BackgroundFetchRecordIdentifier recordIdentifier) -> (Expected<CyberCore::ResourceResponse, CyberCore::ExceptionData> result)
    RetrieveRecordResponseBody(CyberCore::BackgroundFetchRecordIdentifier recordIdentifier, WebKit::RetrieveRecordResponseBodyCallbackIdentifier callbackIdentifier)
}
#endif // ENABLE(SERVICE_WORKER)
