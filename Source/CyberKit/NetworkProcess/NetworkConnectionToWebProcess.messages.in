messages -> NetworkConnectionToWebProcess LegacyReceiver {

    ScheduleResourceLoad(CyberKit::NetworkResourceLoadParameters resourceLoadParameters)
    PerformSynchronousLoad(CyberKit::NetworkResourceLoadParameters resourceLoadParameters) -> (CyberCore::ResourceError error, CyberCore::ResourceResponse response, Vector<char> data) Synchronous
    TestProcessIncomingSyncMessagesWhenWaitingForSyncReply(CyberKit::WebPageProxyIdentifier pageID) -> (bool handled) Synchronous
    LoadPing(CyberKit::NetworkResourceLoadParameters resourceLoadParameters)
    RemoveLoadIdentifier(uint64_t resourceLoadIdentifier)
    PageLoadCompleted(CyberCore::PageIdentifier webPageID)
    BrowsingContextRemoved(CyberKit::WebPageProxyIdentifier webPageProxyID, CyberCore::PageIdentifier webPageID, CyberCore::FrameIdentifier webFrameID)
    PrefetchDNS(String hostname)
    SendH2Ping(CyberKit::NetworkResourceLoadParameters parameters) -> (Expected<Seconds, CyberCore::ResourceError> result) Async
    PreconnectTo(Optional<uint64_t> preconnectionIdentifier, CyberKit::NetworkResourceLoadParameters loadParameters);

    StartDownload(CyberKit::DownloadID downloadID, CyberCore::ResourceRequest request, enum:bool Optional<CyberKit::NavigatingToAppBoundDomain> isNavigatingToAppBoundDomain, String suggestedName)
    ConvertMainResourceLoadToDownload(uint64_t mainResourceLoadIdentifier, CyberKit::DownloadID downloadID, CyberCore::ResourceRequest request, CyberCore::ResourceResponse response, enum:bool Optional<CyberKit::NavigatingToAppBoundDomain> isNavigatingToAppBoundDomain)

    CookiesForDOM(URL firstParty, struct CyberCore::SameSiteInfo sameSiteInfo, URL url, CyberCore::FrameIdentifier frameID, CyberCore::PageIdentifier pageID, enum:bool CyberCore::IncludeSecureCookies includeSecureCookies, enum:bool CyberCore::ShouldAskITP shouldAskITP, enum:bool CyberCore::ShouldRelaxThirdPartyCookieBlocking shouldRelaxThirdPartyCookieBlocking) -> (String cookieString, bool didAccessSecureCookies) Synchronous
    SetCookiesFromDOM(URL firstParty, struct CyberCore::SameSiteInfo sameSiteInfo, URL url, CyberCore::FrameIdentifier frameID, CyberCore::PageIdentifier pageID, enum:bool CyberCore::ShouldAskITP shouldAskITP, String cookieString, enum:bool CyberCore::ShouldRelaxThirdPartyCookieBlocking shouldRelaxThirdPartyCookieBlocking)
    CookieRequestHeaderFieldValue(URL firstParty, struct CyberCore::SameSiteInfo sameSiteInfo, URL url, Optional<CyberCore::FrameIdentifier> frameID, Optional<CyberCore::PageIdentifier> pageID, enum:bool CyberCore::IncludeSecureCookies includeSecureCookies, enum:bool CyberCore::ShouldAskITP shouldAskITP, enum:bool CyberCore::ShouldRelaxThirdPartyCookieBlocking shouldRelaxThirdPartyCookieBlocking) -> (String cookieString, bool didAccessSecureCookies) Synchronous
    GetRawCookies(URL firstParty, struct CyberCore::SameSiteInfo sameSiteInfo, URL url, Optional<CyberCore::FrameIdentifier> frameID, Optional<CyberCore::PageIdentifier> pageID, enum:bool CyberCore::ShouldAskITP shouldAskITP, enum:bool CyberCore::ShouldRelaxThirdPartyCookieBlocking shouldRelaxThirdPartyCookieBlocking) -> (Vector<CyberCore::Cookie> cookies) Synchronous
    SetRawCookie(struct CyberCore::Cookie cookie)
    DeleteCookie(URL url, String cookieName)
    DomCookiesForHost(String host, bool subscribeToCookieChangeNotifications) -> (Vector<CyberCore::Cookie> cookies) Synchronous
#if HAVE(COOKIE_CHANGE_LISTENER_API)
    UnsubscribeFromCookieChangeNotifications(HashSet<String> hosts)
#endif

    RegisterFileBlobURL(URL url, String path, String replacementPath, CyberKit::SandboxExtension::Handle extensionHandle, String contentType)
    RegisterBlobURL(URL url, Vector<CyberCore::BlobPart> blobParts, String contentType)
    RegisterBlobURLFromURL(URL url, URL srcURL)
    RegisterBlobURLOptionallyFileBacked(URL url, URL srcURL, String fileBackedPath, String contentType)
    RegisterBlobURLForSlice(URL url, URL srcURL, int64_t start, int64_t end)
    UnregisterBlobURL(URL url)
    BlobSize(URL url) -> (uint64_t resultSize) Synchronous
    WriteBlobsToTemporaryFiles(Vector<String> blobURLs) -> (Vector<String> fileNames) Async

    SetCaptureExtraNetworkLoadMetricsEnabled(bool enabled)

    CreateSocketStream(URL url, String cachePartition, CyberKit::WebSocketIdentifier identifier)
    CreateSocketChannel(CyberCore::ResourceRequest request, String protocol, CyberKit::WebSocketIdentifier identifier)

#if ENABLE(RESOURCE_LOAD_STATISTICS)
    RemoveStorageAccessForFrame(CyberCore::FrameIdentifier frameID, CyberCore::PageIdentifier pageID);
    ClearPageSpecificDataForResourceLoadStatistics(CyberCore::PageIdentifier pageID);
    LogUserInteraction(CyberCore::RegistrableDomain domain)
    ResourceLoadStatisticsUpdated(Vector<CyberCore::ResourceLoadStatistics> statistics) -> () Async
    HasStorageAccess(CyberCore::RegistrableDomain subFrameDomain, CyberCore::RegistrableDomain topFrameDomain, CyberCore::FrameIdentifier frameID, CyberCore::PageIdentifier pageID) -> (bool hasStorageAccess) Async
    RequestStorageAccess(CyberCore::RegistrableDomain subFrameDomain, CyberCore::RegistrableDomain topFrameDomain, CyberCore::FrameIdentifier frameID, CyberCore::PageIdentifier webPageID, CyberKit::WebPageProxyIdentifier webPageProxyID, enum:bool CyberCore::StorageAccessScope scope) -> (struct CyberCore::RequestStorageAccessResult result) Async
    RequestStorageAccessUnderOpener(CyberCore::RegistrableDomain domainInNeedOfStorageAccess, CyberCore::PageIdentifier openerPageID, CyberCore::RegistrableDomain openerDomain)
#endif

    AddOriginAccessAllowListEntry(String sourceOrigin, String destinationProtocol, String destinationHost, bool allowDestinationSubdomains);
    RemoveOriginAccessAllowListEntry(String sourceOrigin, String destinationProtocol, String destinationHost, bool allowDestinationSubdomains);
    ResetOriginAccessAllowLists();

    GetNetworkLoadInformationResponse(uint64_t resourceLoadIdentifier) -> (CyberCore::ResourceResponse response) Synchronous
    GetNetworkLoadIntermediateInformation(uint64_t resourceLoadIdentifier) -> (Vector<CyberCore::NetworkTransactionInformation> transactions) Synchronous
    TakeNetworkLoadInformationMetrics(uint64_t resourceLoadIdentifier) -> (CyberCore::NetworkLoadMetrics networkMetrics) Synchronous

#if ENABLE(SERVICE_WORKER)
    EstablishSWContextConnection(CyberCore::RegistrableDomain domain) -> () Async
    CloseSWContextConnection()
#endif

    CreateRTCProvider() -> () Async

    UpdateQuotaBasedOnSpaceUsageForTesting(struct CyberCore::ClientOrigin origin)
    CreateNewMessagePortChannel(struct CyberCore::MessagePortIdentifier port1, struct CyberCore::MessagePortIdentifier port2)
    EntangleLocalPortInThisProcessToRemote(struct CyberCore::MessagePortIdentifier local, struct CyberCore::MessagePortIdentifier remote)
    MessagePortDisentangled(struct CyberCore::MessagePortIdentifier local)
    MessagePortClosed(struct CyberCore::MessagePortIdentifier local)
    TakeAllMessagesForPort(struct CyberCore::MessagePortIdentifier port) -> (Vector<CyberCore::MessageWithMessagePorts> messages, uint64_t messageBatchIdentifier) Async
    PostMessageToRemote(struct CyberCore::MessageWithMessagePorts message, struct CyberCore::MessagePortIdentifier remote)
    CheckRemotePortForActivity(struct CyberCore::MessagePortIdentifier port) -> (bool hasActivity) Async
    DidDeliverMessagePortMessages(uint64_t messageBatchIdentifier)
    RegisterURLSchemesAsCORSEnabled(Vector<String> schemes);
    SetCORSDisablingPatterns(CyberCore::PageIdentifier pageIdentifier, Vector<String> patterns)
}
