prefix=@CMAKE_BINARY_DIR@
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}

Name: WPE CyberKit
Description: Embeddable Web content engine
URL: https://wpewebkit.org
Version: @PROJECT_VERSION@
Requires: glib-2.0 libsoup-@SOUP_API_VERSION@ wpe-1.0
Libs: -L${libdir} -lWPECyberKit-@WPE_API_VERSION@
Cflags: -I${includedir}/DerivedSources/ForwardingHeaders/wpe -I${includedir}/DerivedSources/CyberKit/ -I${includedir}/DerivedSources/ForwardingHeaders/wpe-jsc -I${includedir}/CyberScriptCoreGLib/Headers -I${includedir}/CyberScriptCoreGLib/DerivedSources
