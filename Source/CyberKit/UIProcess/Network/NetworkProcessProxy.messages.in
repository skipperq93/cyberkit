messages -> NetworkProcessProxy LegacyReceiver NotRefCounted {
    DidReceiveAuthenticationChallenge(PAL::SessionID sessionID, CyberKit::WebPageProxyIdentifier pageID, Optional<CyberCore::SecurityOriginData> topOrigin, CyberCore::AuthenticationChallenge challenge, bool negotiatedLegacyTLS, uint64_t challengeID)
    NegotiatedLegacyTLS(CyberKit::WebPageProxyIdentifier pageID)
    DidNegotiateModernTLS(CyberKit::WebPageProxyIdentifier pageID, CyberCore::AuthenticationChallenge challenge)

    DidFetchWebsiteData(CyberKit::CallbackID callbackID, struct CyberKit::WebsiteData websiteData)
    DidDeleteWebsiteData(CyberKit::CallbackID callbackID)
    DidDeleteWebsiteDataForOrigins(CyberKit::CallbackID callbackID)

    DidSyncAllCookies()

    TestProcessIncomingSyncMessagesWhenWaitingForSyncReply(CyberKit::WebPageProxyIdentifier pageID) -> (bool handled) Synchronous
    TerminateUnresponsiveServiceWorkerProcesses(CyberCore::ProcessIdentifier processIdentifier)

    SetIsHoldingLockedFiles(bool isHoldingLockedFiles)

    # Diagnostic messages logging
    LogDiagnosticMessage(CyberKit::WebPageProxyIdentifier pageID, String message, String description, enum:bool CyberCore::ShouldSample shouldSample)
    LogDiagnosticMessageWithResult(CyberKit::WebPageProxyIdentifier pageID, String message, String description, uint32_t result, enum:bool CyberCore::ShouldSample shouldSample)
    LogDiagnosticMessageWithValue(CyberKit::WebPageProxyIdentifier pageID, String message, String description, double value, unsigned significantFigures, enum:bool CyberCore::ShouldSample shouldSample)

#if ENABLE(RESOURCE_LOAD_STATISTICS)
    LogTestingEvent(PAL::SessionID sessionID, String event)
    NotifyResourceLoadStatisticsProcessed()
    NotifyWebsiteDataDeletionForRegistrableDomainsFinished()
    NotifyWebsiteDataScanForRegistrableDomainsFinished()
    NotifyResourceLoadStatisticsTelemetryFinished(unsigned numberOfPrevalentResources, unsigned numberOfPrevalentResourcesWithUserInteraction, unsigned numberOfPrevalentResourcesWithoutUserInteraction, unsigned topPrevalentResourceWithUserInteractionDaysSinceUserInteraction, unsigned medianDaysSinceUserInteractionPrevalentResourceWithUserInteraction, unsigned top3NumberOfPrevalentResourcesWithUI, unsigned top3MedianSubFrameWithoutUI, unsigned top3MedianSubResourceWithoutUI, unsigned top3MedianUniqueRedirectsWithoutUI, unsigned top3MedianDataRecordsRemovedWithoutUI)
    RequestStorageAccessConfirm(CyberKit::WebPageProxyIdentifier pageID, CyberCore::FrameIdentifier frameID, CyberCore::RegistrableDomain subFrameDomain, CyberCore::RegistrableDomain topFrameDomain) -> (bool userDidGrantAccess) Async
    DeleteWebsiteDataInUIProcessForRegistrableDomains(PAL::SessionID sessionID, OptionSet<CyberKit::WebsiteDataType> dataTypes, OptionSet<CyberKit::WebsiteDataFetchOption> fetchOptions, Vector<CyberCore::RegistrableDomain> domains) -> (HashSet<CyberCore::RegistrableDomain> domainsWithMatchingDataRecords) Async
    DidCommitCrossSiteLoadWithDataTransferFromPrevalentResource(CyberKit::WebPageProxyIdentifier pageID)
    SetDomainsWithUserInteraction(HashSet<CyberCore::RegistrableDomain> domains)
#endif
#if ENABLE(CONTENT_EXTENSIONS)
    ContentExtensionRules(CyberKit::UserContentControllerIdentifier identifier)
#endif

    RetrieveCacheStorageParameters(PAL::SessionID sessionID)

    TerminateWebProcess(CyberCore::ProcessIdentifier webProcessIdentifier)

#if ENABLE(SERVICE_WORKER)
    EstablishWorkerContextConnectionToNetworkProcess(CyberCore::RegistrableDomain registrableDomain, PAL::SessionID sessionID) -> () Async
    WorkerContextConnectionNoLongerNeeded(CyberCore::ProcessIdentifier identifier)
    RegisterServiceWorkerClientProcess(CyberCore::ProcessIdentifier webProcessIdentifier, CyberCore::ProcessIdentifier serviceWorkerProcessIdentifier)
    UnregisterServiceWorkerClientProcess(CyberCore::ProcessIdentifier webProcessIdentifier, CyberCore::ProcessIdentifier serviceWorkerProcessIdentifier)
#endif

    SetWebProcessHasUploads(CyberCore::ProcessIdentifier processID, bool hasUpload)

    GetAppBoundDomains(PAL::SessionID sessionID) -> (HashSet<CyberCore::RegistrableDomain> appBoundDomains) Async

    RequestStorageSpace(PAL::SessionID sessionID, struct CyberCore::ClientOrigin origin, uint64_t quota, uint64_t currentSize, uint64_t spaceRequired) -> (Optional<uint64_t> newQuota) Async
    
    ResourceLoadDidSendRequest(CyberKit::WebPageProxyIdentifier pageIdentifier, struct CyberKit::ResourceLoadInfo resourceLoadInfo, CyberCore::ResourceRequest request, Optional<IPC::FormDataReference> httpBody)
    ResourceLoadDidPerformHTTPRedirection(CyberKit::WebPageProxyIdentifier pageIdentifier, struct CyberKit::ResourceLoadInfo resourceLoadInfo, CyberCore::ResourceResponse resourceResponse, CyberCore::ResourceRequest request)
    ResourceLoadDidReceiveChallenge(CyberKit::WebPageProxyIdentifier pageIdentifier, struct CyberKit::ResourceLoadInfo resourceLoadInfo, CyberCore::AuthenticationChallenge challenge)
    ResourceLoadDidReceiveResponse(CyberKit::WebPageProxyIdentifier pageIdentifier, struct CyberKit::ResourceLoadInfo resourceLoadInfo, CyberCore::ResourceResponse response)
    ResourceLoadDidCompleteWithError(CyberKit::WebPageProxyIdentifier pageIdentifier, struct CyberKit::ResourceLoadInfo resourceLoadInfo, CyberCore::ResourceResponse response, CyberCore::ResourceError error)
}
