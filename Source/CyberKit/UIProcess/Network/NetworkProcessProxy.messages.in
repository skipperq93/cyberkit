messages -> NetworkProcessProxy LegacyReceiver {
    DidCreateNetworkConnectionToWebProcess(IPC::Attachment connectionIdentifier)

    DidReceiveAuthenticationChallenge(CyberCore::PageIdentifier pageID, uint64_t frameID, CyberCore::AuthenticationChallenge challenge, uint64_t challengeID)

    DidFetchWebsiteData(uint64_t callbackID, struct CyberKit::WebsiteData websiteData)
    DidDeleteWebsiteData(uint64_t callbackID)
    DidDeleteWebsiteDataForOrigins(uint64_t callbackID)

    DidSyncAllCookies()

    TestProcessIncomingSyncMessagesWhenWaitingForSyncReply(CyberCore::PageIdentifier webPageID) -> (bool handled) Synchronous

    ProcessReadyToSuspend()
    SetIsHoldingLockedFiles(bool isHoldingLockedFiles)

    # Diagnostic messages logging
    LogDiagnosticMessage(CyberCore::PageIdentifier pageID, String message, String description, enum:bool CyberCore::ShouldSample shouldSample)
    LogDiagnosticMessageWithResult(CyberCore::PageIdentifier pageID, String message, String description, uint32_t result, enum:bool CyberCore::ShouldSample shouldSample)
    LogDiagnosticMessageWithValue(CyberCore::PageIdentifier pageID, String message, String description, double value, unsigned significantFigures, enum:bool CyberCore::ShouldSample shouldSample)
    LogGlobalDiagnosticMessageWithValue(String message, String description, double value, unsigned significantFigures, enum:bool CyberCore::ShouldSample shouldSample)

#if ENABLE(RESOURCE_LOAD_STATISTICS)
    LogTestingEvent(PAL::SessionID sessionID, String event)
    NotifyResourceLoadStatisticsProcessed()
    NotifyWebsiteDataDeletionForRegistrableDomainsFinished()
    NotifyWebsiteDataScanForRegistrableDomainsFinished()
    NotifyResourceLoadStatisticsTelemetryFinished(unsigned totalPrevalentResources, unsigned totalPrevalentResourcesWithUserInteraction, unsigned top3SubframeUnderTopFrameOrigins)
    RequestStorageAccessConfirm(CyberCore::PageIdentifier pageID, uint64_t frameID, CyberCore::RegistrableDomain subFrameDomain, CyberCore::RegistrableDomain topFrameDomain) -> (bool userDidGrantAccess) Async
    DeleteWebsiteDataInUIProcessForRegistrableDomains(PAL::SessionID sessionID, OptionSet<CyberKit::WebsiteDataType> dataTypes, OptionSet<CyberKit::WebsiteDataFetchOption> fetchOptions, Vector<CyberCore::RegistrableDomain> domains) -> (HashSet<CyberCore::RegistrableDomain> domainsWithMatchingDataRecords) Async
    DidCommitCrossSiteLoadWithDataTransferFromPrevalentResource(CyberCore::PageIdentifier pageID)
#endif
#if ENABLE(CONTENT_EXTENSIONS)
    ContentExtensionRules(CyberKit::UserContentControllerIdentifier identifier)
#endif

    RetrieveCacheStorageParameters(PAL::SessionID sessionID)

#if ENABLE(SANDBOX_EXTENSIONS)
    GetSandboxExtensionsForBlobFiles(Vector<String> paths) -> (CyberKit::SandboxExtension::HandleArray extensions) Async
#endif

#if ENABLE(SERVICE_WORKER)
    EstablishWorkerContextConnectionToNetworkProcess(CyberCore::RegistrableDomain registrableDomain)
    EstablishWorkerContextConnectionToNetworkProcessForExplicitSession(CyberCore::RegistrableDomain registrableDomain, PAL::SessionID explicitSession)
#endif

    RequestStorageSpace(PAL::SessionID sessionID, struct CyberCore::ClientOrigin origin, uint64_t quota, uint64_t currentSize, uint64_t spaceRequired) -> (Optional<uint64_t> newQuota) Async
}
