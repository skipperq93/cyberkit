@API_SINGLE_HEADER_CHECK@

#ifndef CyberKitPrintCustomWidget_h
#define CyberKitPrintCustomWidget_h

#include <glib-object.h>
#include <gtk/gtk.h>
#include <webkit/CyberKitDefines.h>

G_BEGIN_DECLS

#define WEBKIT_TYPE_PRINT_CUSTOM_WIDGET            (webkit_print_custom_widget_get_type())
#define WEBKIT_PRINT_CUSTOM_WIDGET(obj)            (G_TYPE_CHECK_INSTANCE_CAST((obj), WEBKIT_TYPE_PRINT_CUSTOM_WIDGET, CyberKitPrintCustomWidget))
#define WEBKIT_IS_PRINT_CUSTOM_WIDGET(obj)         (G_TYPE_CHECK_INSTANCE_TYPE((obj), WEBKIT_TYPE_PRINT_CUSTOM_WIDGET))
#define WEBKIT_PRINT_CUSTOM_WIDGET_CLASS(klass)    (G_TYPE_CHECK_CLASS_CAST((klass),  WEBKIT_TYPE_PRINT_CUSTOM_WIDGET, CyberKitPrintCustomWidgetClass))
#define WEBKIT_IS_PRINT_CUSTOM_WIDGET_CLASS(klass) (G_TYPE_CHECK_CLASS_TYPE((klass),  WEBKIT_TYPE_PRINT_CUSTOM_WIDGET))
#define WEBKIT_PRINT_CUSTOM_WIDGET_GET_CLASS(obj)  (G_TYPE_INSTANCE_GET_CLASS((obj),  WEBKIT_TYPE_PRINT_CUSTOM_WIDGET, CyberKitPrintCustomWidgetClass))

typedef struct _CyberKitPrintCustomWidget        CyberKitPrintCustomWidget;
typedef struct _CyberKitPrintCustomWidgetClass   CyberKitPrintCustomWidgetClass;
typedef struct _CyberKitPrintCustomWidgetPrivate CyberKitPrintCustomWidgetPrivate;

struct _CyberKitPrintCustomWidget {
    GObject parent;

    /*< private >*/
    CyberKitPrintCustomWidgetPrivate *priv;
};

struct _CyberKitPrintCustomWidgetClass {
    GObjectClass parent_class;

    /*< public >*/
    void    (* apply)               (CyberKitPrintCustomWidget *print_custom_widget,
                                     GtkWidget               *widget);
    void    (* update)              (CyberKitPrintCustomWidget *print_custom_widget,
                                     GtkWidget               *widget,
                                     GtkPageSetup            *page_setup,
                                     GtkPrintSettings        *print_settings);

    /*< private >*/
    void    (*_webkit_reserved0) (void);
    void    (*_webkit_reserved1) (void);
    void    (*_webkit_reserved2) (void);
    void    (*_webkit_reserved3) (void);
};

WEBKIT_DEPRECATED GType
webkit_print_custom_widget_get_type   (void);

WEBKIT_DEPRECATED CyberKitPrintCustomWidget *
webkit_print_custom_widget_new        (GtkWidget               *widget,
                                       const char              *title);

WEBKIT_DEPRECATED GtkWidget *
webkit_print_custom_widget_get_widget (CyberKitPrintCustomWidget *print_custom_widget);

WEBKIT_DEPRECATED const gchar *
webkit_print_custom_widget_get_title  (CyberKitPrintCustomWidget *print_custom_widget);

G_END_DECLS

#endif
