@API_SINGLE_HEADER_CHECK@

#ifndef CyberKitPermissionStateQuery_h
#define CyberKitPermissionStateQuery_h

#include <glib-object.h>
#include <@API_INCLUDE_PREFIX@/CyberKitDefines.h>
#include <@API_INCLUDE_PREFIX@/CyberKitSecurityOrigin.h>

G_BEGIN_DECLS

#define WEBKIT_TYPE_PERMISSION_STATE_QUERY (webkit_permission_state_query_get_type())

typedef struct _CyberKitPermissionStateQuery CyberKitPermissionStateQuery;

/**
 * CyberKitPermissionState:
 * @WEBKIT_PERMISSION_STATE_GRANTED: Access to the feature is granted.
 * @WEBKIT_PERMISSION_STATE_DENIED: Access to the feature is denied.
 * @WEBKIT_PERMISSION_STATE_PROMPT: Access to the feature has to be requested via user prompt.
 *
 * Enum values representing query permission results.
 *
 * Since: 2.40
 */
typedef enum {
    WEBKIT_PERMISSION_STATE_GRANTED,
    WEBKIT_PERMISSION_STATE_DENIED,
    WEBKIT_PERMISSION_STATE_PROMPT,
} CyberKitPermissionState;

WEBKIT_API GType
webkit_permission_state_query_get_type    (void);

WEBKIT_API CyberKitPermissionStateQuery *
webkit_permission_state_query_ref                 (CyberKitPermissionStateQuery *query);

WEBKIT_API void
webkit_permission_state_query_unref               (CyberKitPermissionStateQuery *query);

WEBKIT_API const gchar *
webkit_permission_state_query_get_name            (CyberKitPermissionStateQuery *query);

WEBKIT_API CyberKitSecurityOrigin *
webkit_permission_state_query_get_security_origin (CyberKitPermissionStateQuery *query);

WEBKIT_API void
webkit_permission_state_query_finish              (CyberKitPermissionStateQuery *query,
                                                   CyberKitPermissionState       state);

G_END_DECLS

#endif
