messages -> WebPageProxy {
    # UI messages
    CreateNewPage(struct WebKit::FrameInfoData originatingFrameInfoData, WebKit::WebPageProxyIdentifier originatingPageID, CyberCore::ResourceRequest request, struct CyberCore::WindowFeatures windowFeatures, struct WebKit::NavigationActionData navigationActionData) -> (std::optional<CyberCore::PageIdentifier> newPageID, std::optional<WebKit::WebPageCreationParameters> newPageParameters) Synchronous
    ShowPage()
    ClosePage()
    RunJavaScriptAlert(CyberCore::FrameIdentifier frameID, struct WebKit::FrameInfoData frameInfo, String message) -> () Synchronous
    RunJavaScriptConfirm(CyberCore::FrameIdentifier frameID, struct WebKit::FrameInfoData frameInfo, String message) -> (bool result) Synchronous
    RunJavaScriptPrompt(CyberCore::FrameIdentifier frameID, struct WebKit::FrameInfoData frameInfo, String message, String defaultValue) -> (String result) Synchronous
    MouseDidMoveOverElement(struct WebKit::WebHitTestResultData hitTestResultData, uint32_t modifiers, WebKit::UserData userData)

    DidChangeViewportProperties(struct CyberCore::ViewportAttributes attributes)
    DidReceiveEvent(enum:int8_t WebKit::WebEventType eventType, bool handled)
    SetCursor(CyberCore::Cursor cursor)
    SetCursorHiddenUntilMouseMoves(bool hiddenUntilMouseMoves)
    SetStatusText(String statusText)
    SetFocus(bool focused)
    TakeFocus(enum:uint8_t CyberCore::FocusDirection direction)
    FocusFromServiceWorker() -> ()
    FocusedFrameChanged(std::optional<CyberCore::FrameIdentifier> frameID)
    SetRenderTreeSize(uint64_t treeSize)
    SetToolbarsAreVisible(bool toolbarsAreVisible)
    GetToolbarsAreVisible() -> (bool toolbarsAreVisible) Synchronous
    SetMenuBarIsVisible(bool menuBarIsVisible)
    GetMenuBarIsVisible() -> (bool menuBarIsVisible) Synchronous
    SetStatusBarIsVisible(bool statusBarIsVisible)
    GetStatusBarIsVisible() -> (bool statusBarIsVisible) Synchronous
    SetIsResizable(bool isResizable)
    SetWindowFrame(CyberCore::FloatRect windowFrame)
    GetWindowFrame() -> (CyberCore::FloatRect windowFrame) Synchronous
    ScreenToRootView(CyberCore::IntPoint screenPoint) -> (CyberCore::IntPoint windowPoint) Synchronous
    RootViewToScreen(CyberCore::IntRect rect) -> (CyberCore::IntRect screenFrame) Synchronous
    AccessibilityScreenToRootView(CyberCore::IntPoint screenPoint) -> (CyberCore::IntPoint windowPoint) Synchronous
    RootViewToAccessibilityScreen(CyberCore::IntRect rect) -> (CyberCore::IntRect screenFrame) Synchronous

#if PLATFORM(COCOA) || PLATFORM(GTK)
    ShowValidationMessage(CyberCore::IntRect anchorRect, String message)
    HideValidationMessage()
#endif

    RunBeforeUnloadConfirmPanel(CyberCore::FrameIdentifier frameID, struct WebKit::FrameInfoData frameInfo, String message) -> (bool shouldClose) Synchronous
    PageDidScroll(CyberCore::IntPoint scrollPosition)
    SetHasActiveAnimatedScrolls(bool hasActiveAnimatedScrolls)
    RunOpenPanel(CyberCore::FrameIdentifier frameID, struct WebKit::FrameInfoData frameInfo, struct CyberCore::FileChooserSettings parameters)
    ShowShareSheet(struct CyberCore::ShareDataWithParsedURL shareData) -> (bool granted)
    ShowContactPicker(struct CyberCore::ContactsRequestData requestData) -> (std::optional<Vector<CyberCore::ContactInfo>> info)
    PrintFrame(CyberCore::FrameIdentifier frameID, String title, CyberCore::FloatSize pdfFirstPageSize) -> () Synchronous
    RunModal()
    NotifyScrollerThumbIsVisibleInRect(CyberCore::IntRect scrollerThumb)
    RecommendedScrollbarStyleDidChange(int32_t newStyle)
    DidChangeScrollbarsForMainFrame(bool hasHorizontalScrollbar, bool hasVerticalScrollbar)
    DidChangeScrollOffsetPinningForMainFrame(CyberCore::RectEdges<bool> pinnedState)
    DidChangePageCount(unsigned pageCount)
    ThemeColorChanged(CyberCore::Color themeColor)
    PageExtendedBackgroundColorDidChange(CyberCore::Color backgroundColor)
    SampledPageTopColorChanged(CyberCore::Color sampledPageTopColor)
    SetCanShortCircuitHorizontalWheelEvents(bool canShortCircuitHorizontalWheelEvents)

    DidChangeContentSize(CyberCore::IntSize newSize)
    DidChangeIntrinsicContentSize(CyberCore::IntSize newIntrinsicContentSize)

#if ENABLE(INPUT_TYPE_COLOR)
    ShowColorPicker(CyberCore::Color initialColor, CyberCore::IntRect elementRect, Vector<CyberCore::Color> suggestions);
    SetColorPickerColor(CyberCore::Color color);
    EndColorPicker();
#endif

#if ENABLE(DATALIST_ELEMENT)
    ShowDataListSuggestions(struct CyberCore::DataListSuggestionInformation suggestionInformation);
    HandleKeydownInDataList(String key);
    EndDataListSuggestions();
#endif

#if ENABLE(DATE_AND_TIME_INPUT_TYPES)
    ShowDateTimePicker(struct CyberCore::DateTimeChooserParameters params);
    EndDateTimePicker();
#endif

    # Policy messages
    DecidePolicyForResponse(CyberCore::FrameIdentifier frameID, struct WebKit::FrameInfoData frameInfo, CyberCore::PolicyCheckIdentifier policyCheckIdentifier, uint64_t navigationID, CyberCore::ResourceResponse response, CyberCore::ResourceRequest request, bool canShowMIMEType, String downloadAttribute, uint64_t listenerID)
    DecidePolicyForNavigationActionAsync(CyberCore::FrameIdentifier frameID, struct WebKit::FrameInfoData frameInfo, CyberCore::PolicyCheckIdentifier policyCheckIdentifier, uint64_t navigationID, struct WebKit::NavigationActionData navigationActionData, struct WebKit::FrameInfoData originatingFrameInfoData, std::optional<WebKit::WebPageProxyIdentifier> originatingPageID, CyberCore::ResourceRequest originalRequest, CyberCore::ResourceRequest request, IPC::FormDataReference requestBody, CyberCore::ResourceResponse redirectResponse, uint64_t listenerID)
    DecidePolicyForNavigationActionSync(CyberCore::FrameIdentifier frameID, bool isMainFrame, struct WebKit::FrameInfoData frameInfo, CyberCore::PolicyCheckIdentifier policyCheckIdentifier, uint64_t navigationID, struct WebKit::NavigationActionData navigationActionData, struct WebKit::FrameInfoData originatingFrameInfoData, std::optional<WebKit::WebPageProxyIdentifier> originatingPageID, CyberCore::ResourceRequest originalRequest, CyberCore::ResourceRequest request, IPC::FormDataReference requestBody, CyberCore::ResourceResponse redirectResponse) -> (struct WebKit::PolicyDecision PolicyDecision) Synchronous
    DecidePolicyForNewWindowAction(CyberCore::FrameIdentifier frameID, struct WebKit::FrameInfoData frameInfo, CyberCore::PolicyCheckIdentifier policyCheckIdentifier, struct WebKit::NavigationActionData navigationActionData, CyberCore::ResourceRequest request, String frameName, uint64_t listenerID)

    # Progress messages
    DidChangeProgress(double value)
    DidFinishProgress()
    DidStartProgress()

    SetNetworkRequestsInProgress(bool networkRequestsInProgress)

    # Frame lifetime messages
    DidCreateMainFrame(CyberCore::FrameIdentifier frameID)

    # Frame load messages
    DidStartProvisionalLoadForFrame(CyberCore::FrameIdentifier frameID, struct WebKit::FrameInfoData frameInfo, CyberCore::ResourceRequest request, uint64_t navigationID, URL url, URL unreachableURL, WebKit::UserData userData)
    DidReceiveServerRedirectForProvisionalLoadForFrame(CyberCore::FrameIdentifier frameID, uint64_t navigationID, CyberCore::ResourceRequest request, WebKit::UserData userData)
    WillPerformClientRedirectForFrame(CyberCore::FrameIdentifier frameID, String url, double delay, enum:bool CyberCore::LockBackForwardList lockBackForwardList)
    DidCancelClientRedirectForFrame(CyberCore::FrameIdentifier frameID)
    DidChangeProvisionalURLForFrame(CyberCore::FrameIdentifier frameID, uint64_t navigationID, URL url)
    DidFailProvisionalLoadForFrame(CyberCore::FrameIdentifier frameID, struct WebKit::FrameInfoData frameInfo, CyberCore::ResourceRequest request, uint64_t navigationID, String provisionalURL, CyberCore::ResourceError error, enum:bool CyberCore::WillContinueLoading willContinueLoading, WebKit::UserData userData, enum:bool CyberCore::WillInternallyHandleFailure willInternallyHandleFailure)
    DidCommitLoadForFrame(CyberCore::FrameIdentifier frameID, struct WebKit::FrameInfoData frameInfo, CyberCore::ResourceRequest request, uint64_t navigationID, String mimeType, bool hasCustomContentProvider, enum:uint8_t CyberCore::FrameLoadType loadType, CyberCore::CertificateInfo certificateInfo, bool usedLegacyTLS, bool wasPrivateRelayed, bool containsPluginDocument, enum:bool CyberCore::HasInsecureContent hasInsecureContent, enum:uint8_t CyberCore::MouseEventPolicy mouseEventPolicy, WebKit::UserData userData)
    DidFailLoadForFrame(CyberCore::FrameIdentifier frameID, struct WebKit::FrameInfoData frameInfo, CyberCore::ResourceRequest request, uint64_t navigationID, CyberCore::ResourceError error, WebKit::UserData userData)
    DidFinishDocumentLoadForFrame(CyberCore::FrameIdentifier frameID, uint64_t navigationID, WebKit::UserData userData)
    DidFinishLoadForFrame(CyberCore::FrameIdentifier frameID, struct WebKit::FrameInfoData frameInfo, CyberCore::ResourceRequest request, uint64_t navigationID, WebKit::UserData userData)
    DidFirstLayoutForFrame(CyberCore::FrameIdentifier frameID, WebKit::UserData userData)
    DidFirstVisuallyNonEmptyLayoutForFrame(CyberCore::FrameIdentifier frameID, WebKit::UserData userData)
    DidReachLayoutMilestone(OptionSet<CyberCore::LayoutMilestone> layoutMilestones)
    DidReceiveTitleForFrame(CyberCore::FrameIdentifier frameID, String title, WebKit::UserData userData)
    DidDisplayInsecureContentForFrame(CyberCore::FrameIdentifier frameID, WebKit::UserData userData)
    DidRunInsecureContentForFrame(CyberCore::FrameIdentifier frameID, WebKit::UserData userData)
    DidSameDocumentNavigationForFrame(CyberCore::FrameIdentifier frameID, uint64_t navigationID, enum:uint8_t WebKit::SameDocumentNavigationType type, URL url, WebKit::UserData userData)
    DidSameDocumentNavigationForFrameViaJSHistoryAPI(CyberCore::FrameIdentifier frameID, enum:uint8_t WebKit::SameDocumentNavigationType type, URL url, struct WebKit::NavigationActionData navigationActionData, WebKit::UserData userData);
    DidChangeMainDocument(CyberCore::FrameIdentifier frameID)
    DidExplicitOpenForFrame(CyberCore::FrameIdentifier frameID, URL url, String mimeType)
    DidDestroyNavigation(uint64_t navigationID)

    UpdateRemoteFrameSize(CyberCore::FrameIdentifier frameID, CyberCore::IntSize size)

    MainFramePluginHandlesPageScaleGestureDidChange(bool mainFramePluginHandlesPageScaleGesture)

#if PLATFORM(GTK) || PLATFORM(WPE)
    # Resource load messages
    DidInitiateLoadForResource(CyberCore::ResourceLoaderIdentifier resourceID, CyberCore::FrameIdentifier frameID, CyberCore::ResourceRequest request)
    DidSendRequestForResource(CyberCore::ResourceLoaderIdentifier resourceID, CyberCore::FrameIdentifier frameID, CyberCore::ResourceRequest request, CyberCore::ResourceResponse redirectResponse)
    DidReceiveResponseForResource(CyberCore::ResourceLoaderIdentifier resourceID, CyberCore::FrameIdentifier frameID, CyberCore::ResourceResponse response)
    DidFinishLoadForResource(CyberCore::ResourceLoaderIdentifier resourceID, CyberCore::FrameIdentifier frameID, CyberCore::ResourceError error)
