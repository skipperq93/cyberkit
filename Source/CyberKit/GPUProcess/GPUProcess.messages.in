#if ENABLE(GPU_PROCESS)

messages -> GPUProcess LegacyReceiver {
    InitializeGPUProcess(struct CyberKit::GPUProcessCreationParameters processCreationParameters)

    CreateGPUConnectionToWebProcess(CyberCore::ProcessIdentifier processIdentifier, PAL::SessionID sessionID, IPC::Connection::Handle connectionHandle, struct CyberKit::GPUProcessConnectionParameters parameters) -> () AllowedWhenWaitingForSyncReply
    
    UpdateGPUProcessPreferences(struct CyberKit::GPUProcessPreferences preferences)

    PrepareToSuspend(bool isSuspensionImminent, MonotonicTime estimatedSuspendTime) -> ()
    ProcessDidResume()

    AddSession(PAL::SessionID sessionID, struct CyberKit::GPUProcessSessionParameters parameters)
    RemoveSession(PAL::SessionID sessionID)

#if ENABLE(MEDIA_STREAM)
    SetMockCaptureDevicesEnabled(bool isEnabled)
    SetOrientationForMediaCapture(CyberCore::IntDegrees orientation);
    UpdateSandboxAccess(Vector<CyberKit::SandboxExtension::Handle> extensions);
    UpdateCaptureAccess(bool allowAudioCapture, bool allowVideoCapture, bool allowDisplayCapture, CyberCore::ProcessIdentifier processID) -> ()
    UpdateCaptureOrigin(CyberCore::SecurityOriginData originData, CyberCore::ProcessIdentifier processID)
    AddMockMediaDevice(struct CyberCore::MockMediaDevice device)
    ClearMockMediaDevices()
    RemoveMockMediaDevice(String persistentId)
    SetMockMediaDeviceIsEphemeral(String persistentId, bool isEphemeral)
    ResetMockMediaDevices()
    SetMockCaptureDevicesInterrupted(bool isCameraInterrupted, bool isMicrophoneInterrupted)
    TriggerMockMicrophoneConfigurationChange()
#endif
#if HAVE(SC_CONTENT_SHARING_PICKER)
    SetUseSCContentSharingPicker(bool use)
#endif
#if PLATFORM(MAC)
    DisplayConfigurationChanged(CGDirectDisplayID displayID, CGDisplayChangeSummaryFlags flags)
    SetScreenProperties(struct CyberCore::ScreenProperties screenProperties)
#endif

#endif

#if HAVE(SCREEN_CAPTURE_KIT)
    PromptForGetDisplayMedia(enum:uint8_t CyberCore::DisplayCapturePromptType type) -> (std::optional<CyberCore::CaptureDevice> device)
#endif

#if ENABLE(VIDEO)
    RequestBitmapImageForCurrentTime(CyberCore::ProcessIdentifier processIdentifier, CyberCore::MediaPlayerIdentifier playerIdentifier) -> (CyberKit::ShareableBitmap::Handle handle)
#endif

#if ENABLE(CFPREFS_DIRECT_MODE)
    NotifyPreferencesChanged(String domain, String key, std::optional<String> encodedValue)
#endif

#if PLATFORM(MAC)
    OpenDirectoryCacheInvalidated(CyberKit::SandboxExtension::Handle handle)
#endif

#if HAVE(AUDIO_COMPONENT_SERVER_REGISTRATIONS)
    ConsumeAudioComponentRegistrations(IPC::SharedBufferReference registrationData)
#endif

#if HAVE(POWERLOG_TASK_MODE_QUERY)
    EnablePowerLogging(CyberKit::SandboxExtension::Handle handle)
#endif

    WebProcessConnectionCountForTesting() -> (uint64_t count)
}

#endif // ENABLE(GPU_PROCESS)
