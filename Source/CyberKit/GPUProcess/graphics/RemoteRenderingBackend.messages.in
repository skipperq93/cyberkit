#if ENABLE(GPU_PROCESS)

messages -> RemoteRenderingBackend NotRefCounted Stream {
    CreateImageBuffer(CyberCore::FloatSize logicalSize, CyberCore::RenderingMode renderingMode, CyberCore::RenderingPurpose renderingPurpose, float resolutionScale, CyberCore::DestinationColorSpace colorSpace, enum:uint8_t CyberCore::PixelFormat pixelFormat, CyberCore::RenderingResourceIdentifier renderingResourceIdentifier)
    GetPixelBufferForImageBuffer(CyberCore::RenderingResourceIdentifier imageBuffer, struct CyberCore::PixelBufferFormat outputFormat, CyberCore::IntRect srcRect) -> () Synchronous
    GetPixelBufferForImageBufferWithNewMemory(CyberCore::RenderingResourceIdentifier imageBuffer, CyberKit::SharedMemory::Handle handle, struct CyberCore::PixelBufferFormat outputFormat, CyberCore::IntRect srcRect) -> () Synchronous NotStreamEncodable
    DestroyGetPixelBufferSharedMemory()
    PutPixelBufferForImageBuffer(CyberCore::RenderingResourceIdentifier imageBuffer, Ref<CyberCore::PixelBuffer> pixelBuffer,  CyberCore::IntRect srcRect, CyberCore::IntPoint destPoint, enum:uint8_t CyberCore::AlphaPremultiplication destFormat)
    GetShareableBitmapForImageBuffer(CyberCore::RenderingResourceIdentifier imageBuffer, enum:bool CyberCore::PreserveResolution preserveResolution) -> (CyberKit::ShareableBitmap::Handle handle) Synchronous NotStreamEncodableReply
    GetFilteredImageForImageBuffer(CyberCore::RenderingResourceIdentifier imageBuffer, Ref<CyberCore::Filter> filter) -> (CyberKit::ShareableBitmap::Handle handle) Synchronous NotStreamEncodableReply
    CacheNativeImage(CyberKit::ShareableBitmap::Handle handle, CyberCore::RenderingResourceIdentifier renderingResourceIdentifier) NotStreamEncodable
    CacheFont(CyberCore::Font::Attributes data, CyberCore::FontPlatformData::Attributes platformData, std::optional<CyberCore::RenderingResourceIdentifier> renderingResourceIdentifier) NotStreamEncodable
    CacheFontCustomPlatformData(Ref<CyberCore::FontCustomPlatformData> customPlatformData) NotStreamEncodable
    CacheDecomposedGlyphs(Ref<CyberCore::DecomposedGlyphs> decomposedGlyphs) NotStreamEncodable
    CacheGradient(Ref<CyberCore::Gradient> gradient, CyberCore::RenderingResourceIdentifier renderingResourceIdentifier) NotStreamEncodable
    ReleaseAllResources()
    ReleaseAllImageResources()
    ReleaseRenderingResource(CyberCore::RenderingResourceIdentifier renderingResourceIdentifier)

#if PLATFORM(COCOA)
    PrepareBuffersForDisplay(Vector<CyberKit::PrepareBackingStoreBuffersInputData> swapBuffersInput) -> (Vector<CyberKit::PrepareBackingStoreBuffersOutputData> swapBuffersOutput) Synchronous NotStreamEncodable NotStreamEncodableReply
#endif

    MarkSurfacesVolatile(CyberKit::MarkSurfacesAsVolatileRequestIdentifier requestIdentifier, Vector<CyberCore::RenderingResourceIdentifier> renderingResourceIdentifiers)
    FinalizeRenderingUpdate(CyberKit::RenderingUpdateID renderingUpdateID)

    MoveToSerializedBuffer(CyberCore::RenderingResourceIdentifier sourceImageBuffer, CyberKit::RemoteSerializedImageBufferWriteReference destination)
    MoveToImageBuffer(CyberKit::RemoteSerializedImageBufferWriteReference source, CyberCore::RenderingResourceIdentifier destinationImageBuffer)

    CreateRemoteGPU(CyberKit::WebGPUIdentifier identifier, IPC::StreamServerConnection::Handle serverConnection) AllowedWhenWaitingForSyncReply NotStreamEncodable
    ReleaseRemoteGPU(CyberKit::WebGPUIdentifier identifier) AllowedWhenWaitingForSyncReply

    CreateRemoteBarcodeDetector(CyberKit::ShapeDetectionIdentifier identifier, CyberCore::ShapeDetection::BarcodeDetectorOptions barcodeDetectorOptions) AllowedWhenWaitingForSyncReply
    ReleaseRemoteBarcodeDetector(CyberKit::ShapeDetectionIdentifier identifier) AllowedWhenWaitingForSyncReply
    GetRemoteBarcodeDetectorSupportedFormats() -> (Vector<CyberCore::ShapeDetection::BarcodeFormat> formats) Async
    CreateRemoteFaceDetector(CyberKit::ShapeDetectionIdentifier identifier, CyberCore::ShapeDetection::FaceDetectorOptions faceDetectorOptions) AllowedWhenWaitingForSyncReply
    ReleaseRemoteFaceDetector(CyberKit::ShapeDetectionIdentifier identifier) AllowedWhenWaitingForSyncReply
    CreateRemoteTextDetector(CyberKit::ShapeDetectionIdentifier identifier) AllowedWhenWaitingForSyncReply
    ReleaseRemoteTextDetector(CyberKit::ShapeDetectionIdentifier identifier) AllowedWhenWaitingForSyncReply
}

#endif // ENABLE(GPU_PROCESS)
