header: <CyberCore/PathSegmentData.h>
[AdditionalEncoder=StreamConnectionEncoder, CustomHeader] struct CyberCore::PathMoveTo {
    CyberCore::FloatPoint point;
};

header: <CyberCore/PathSegmentData.h>
[AdditionalEncoder=StreamConnectionEncoder, CustomHeader] struct CyberCore::PathLineTo {
    CyberCore::FloatPoint point;
};

header: <CyberCore/PathSegmentData.h>
[AdditionalEncoder=StreamConnectionEncoder, CustomHeader] struct CyberCore::PathQuadCurveTo {
    CyberCore::FloatPoint controlPoint;
    CyberCore::FloatPoint endPoint;
};

header: <CyberCore/PathSegmentData.h>
[AdditionalEncoder=StreamConnectionEncoder, CustomHeader] struct CyberCore::PathBezierCurveTo {
    CyberCore::FloatPoint controlPoint1;
    CyberCore::FloatPoint controlPoint2;
    CyberCore::FloatPoint endPoint;
};

header: <CyberCore/PathSegmentData.h>
[AdditionalEncoder=StreamConnectionEncoder, CustomHeader] struct CyberCore::PathArcTo {
    CyberCore::FloatPoint controlPoint1;
    CyberCore::FloatPoint controlPoint2;
    float radius;
};

header: <CyberCore/PathSegmentData.h>
[AdditionalEncoder=StreamConnectionEncoder, CustomHeader] struct CyberCore::PathArc {
    CyberCore::FloatPoint center;
    float radius;
    float startAngle;
    float endAngle;
    CyberCore::RotationDirection direction;
};

header: <CyberCore/PathSegmentData.h>
[AdditionalEncoder=StreamConnectionEncoder, CustomHeader] struct CyberCore::PathEllipse {
    CyberCore::FloatPoint center;
    float radiusX;
    float radiusY;
    float rotation;
    float startAngle;
    float endAngle;
    CyberCore::RotationDirection direction;
};

header: <CyberCore/PathSegmentData.h>
[AdditionalEncoder=StreamConnectionEncoder, CustomHeader] struct CyberCore::PathEllipseInRect {
    CyberCore::FloatRect rect;
};

header: <CyberCore/PathSegmentData.h>
[AdditionalEncoder=StreamConnectionEncoder, CustomHeader] struct CyberCore::PathRect {
    CyberCore::FloatRect rect;
};

header: <CyberCore/PathSegmentData.h>
[Nested] enum class CyberCore::PathRoundedRect::Strategy : uint8_t {
    PreferNative,
    PreferBezier
};

header: <CyberCore/PathSegmentData.h>
[AdditionalEncoder=StreamConnectionEncoder, CustomHeader] struct CyberCore::PathRoundedRect {
    CyberCore::FloatRoundedRect roundedRect;
    CyberCore::PathRoundedRect::Strategy strategy;
};

header: <CyberCore/PathSegmentData.h>
[AdditionalEncoder=StreamConnectionEncoder, CustomHeader] struct CyberCore::PathDataLine {
    CyberCore::FloatPoint start;
    CyberCore::FloatPoint end;
};

header: <CyberCore/PathSegmentData.h>
[AdditionalEncoder=StreamConnectionEncoder, CustomHeader] struct CyberCore::PathDataQuadCurve {
    CyberCore::FloatPoint start;
    CyberCore::FloatPoint controlPoint;
    CyberCore::FloatPoint endPoint;
};

header: <CyberCore/PathSegmentData.h>
[AdditionalEncoder=StreamConnectionEncoder, CustomHeader] struct CyberCore::PathDataBezierCurve {
    CyberCore::FloatPoint start;
    CyberCore::FloatPoint controlPoint1;
    CyberCore::FloatPoint controlPoint2;
    CyberCore::FloatPoint endPoint;
};

header: <CyberCore/PathSegmentData.h>
[AdditionalEncoder=StreamConnectionEncoder, CustomHeader] struct CyberCore::PathDataArc {
