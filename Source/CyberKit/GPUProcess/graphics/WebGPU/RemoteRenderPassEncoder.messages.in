#if ENABLE(GPU_PROCESS)

messages -> RemoteRenderPassEncoder NotRefCounted Stream {
    void Destruct()
    void SetPipeline(CyberKit::WebGPUIdentifier identifier)
    void SetIndexBuffer(CyberKit::WebGPUIdentifier identifier, CyberCore::WebGPU::IndexFormat indexFormat, std::optional<CyberCore::WebGPU::Size64> offset, std::optional<CyberCore::WebGPU::Size64> size)
    void SetVertexBuffer(CyberCore::WebGPU::Index32 slot, CyberKit::WebGPUIdentifier identifier, std::optional<CyberCore::WebGPU::Size64> offset, std::optional<CyberCore::WebGPU::Size64> size)
    void Draw(CyberCore::WebGPU::Size32 vertexCount, std::optional<CyberCore::WebGPU::Size32> instanceCount, std::optional<CyberCore::WebGPU::Size32> firstVertex, std::optional<CyberCore::WebGPU::Size32> firstInstance)
    void DrawIndexed(CyberCore::WebGPU::Size32 indexCount, std::optional<CyberCore::WebGPU::Size32> instanceCount, std::optional<CyberCore::WebGPU::Size32> firstIndex, std::optional<CyberCore::WebGPU::SignedOffset32> baseVertex, std::optional<CyberCore::WebGPU::Size32> firstInstance)
    void DrawIndirect(CyberKit::WebGPUIdentifier indirectBuffer, CyberCore::WebGPU::Size64 indirectOffset)
    void DrawIndexedIndirect(CyberKit::WebGPUIdentifier indirectBuffer, CyberCore::WebGPU::Size64 indirectOffset)
    void SetBindGroup(CyberCore::WebGPU::Index32 index, CyberKit::WebGPUIdentifier identifier, std::optional<Vector<CyberCore::WebGPU::BufferDynamicOffset>> dynamicOffsets)
    void PushDebugGroup(String groupLabel)
    void PopDebugGroup()
    void InsertDebugMarker(String markerLabel)
    void SetViewport(float x, float y, float width, float height, float minDepth, float maxDepth)
    void SetScissorRect(CyberCore::WebGPU::IntegerCoordinate x, CyberCore::WebGPU::IntegerCoordinate y, CyberCore::WebGPU::IntegerCoordinate width, CyberCore::WebGPU::IntegerCoordinate height)
    void SetBlendConstant(CyberKit::WebGPU::Color color)
    void SetStencilReference(CyberCore::WebGPU::StencilValue stencilValue)
    void BeginOcclusionQuery(CyberCore::WebGPU::Size32 queryIndex)
    void EndOcclusionQuery()
    void ExecuteBundles(Vector<CyberKit::WebGPUIdentifier> bundles)
    void End()
    void SetLabel(String label)
}

#endif
