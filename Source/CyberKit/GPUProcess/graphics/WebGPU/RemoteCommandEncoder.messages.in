#if ENABLE(GPU_PROCESS)

messages -> RemoteCommandEncoder NotRefCounted Stream {
    void BeginRenderPass(CyberKit::WebGPU::RenderPassDescriptor descriptor, CyberKit::WebGPUIdentifier identifier)
    void BeginComputePass(std::optional<CyberKit::WebGPU::ComputePassDescriptor> descriptor, CyberKit::WebGPUIdentifier identifier)
    void CopyBufferToBuffer(CyberKit::WebGPUIdentifier source, PAL::WebGPU::Size64 sourceOffset, CyberKit::WebGPUIdentifier destination, PAL::WebGPU::Size64 destinationOffset, PAL::WebGPU::Size64 size)
    void CopyBufferToTexture(CyberKit::WebGPU::ImageCopyBuffer source, CyberKit::WebGPU::ImageCopyTexture destination, CyberKit::WebGPU::Extent3D copySize)
    void CopyTextureToBuffer(CyberKit::WebGPU::ImageCopyTexture source, CyberKit::WebGPU::ImageCopyBuffer destination, CyberKit::WebGPU::Extent3D copySize)
    void CopyTextureToTexture(CyberKit::WebGPU::ImageCopyTexture source, CyberKit::WebGPU::ImageCopyTexture destination, CyberKit::WebGPU::Extent3D copySize)
    void ClearBuffer(CyberKit::WebGPUIdentifier buffer, PAL::WebGPU::Size64 offset, std::optional<PAL::WebGPU::Size64> size)
    void Destruct()
    void PushDebugGroup(String groupLabel)
    void PopDebugGroup()
    void InsertDebugMarker(String markerLabel)
    void WriteTimestamp(CyberKit::WebGPUIdentifier identifier, PAL::WebGPU::Size32 queryIndex)
    void ResolveQuerySet(CyberKit::WebGPUIdentifier identifier, PAL::WebGPU::Size32 firstQuery, PAL::WebGPU::Size32 queryCount, CyberKit::WebGPUIdentifier destination, PAL::WebGPU::Size64 destinationOffset)
    void Finish(CyberKit::WebGPU::CommandBufferDescriptor descriptor, CyberKit::WebGPUIdentifier identifier)
    void SetLabel(String label)
}

#endif
