#if ENABLE(GPU_PROCESS)

messages -> RemoteDevice NotRefCounted Stream {
    void Destroy()
    void CreateBuffer(CyberKit::WebGPU::BufferDescriptor descriptor, CyberKit::WebGPUIdentifier identifier)
    void CreateTexture(CyberKit::WebGPU::TextureDescriptor descriptor, CyberKit::WebGPUIdentifier identifier)
    void CreateSampler(CyberKit::WebGPU::SamplerDescriptor descriptor, CyberKit::WebGPUIdentifier identifier)
    void ImportExternalTexture(CyberKit::WebGPU::ExternalTextureDescriptor descriptor, CyberKit::WebGPUIdentifier identifier)
    void CreateBindGroupLayout(CyberKit::WebGPU::BindGroupLayoutDescriptor descriptor, CyberKit::WebGPUIdentifier identifier)
    void CreatePipelineLayout(CyberKit::WebGPU::PipelineLayoutDescriptor descriptor, CyberKit::WebGPUIdentifier identifier)
    void CreateBindGroup(CyberKit::WebGPU::BindGroupDescriptor descriptor, CyberKit::WebGPUIdentifier identifier)
    void CreateShaderModule(CyberKit::WebGPU::ShaderModuleDescriptor descriptor, CyberKit::WebGPUIdentifier identifier)
    void CreateComputePipeline(CyberKit::WebGPU::ComputePipelineDescriptor descriptor, CyberKit::WebGPUIdentifier identifier)
    void CreateRenderPipeline(CyberKit::WebGPU::RenderPipelineDescriptor descriptor, CyberKit::WebGPUIdentifier identifier)
    void CreateComputePipelineAsync(CyberKit::WebGPU::ComputePipelineDescriptor descriptor, CyberKit::WebGPUIdentifier identifier) -> (bool success)
    void CreateRenderPipelineAsync(CyberKit::WebGPU::RenderPipelineDescriptor descriptor, CyberKit::WebGPUIdentifier identifier) -> (bool success)
    void CreateCommandEncoder(std::optional<CyberKit::WebGPU::CommandEncoderDescriptor> descriptor, CyberKit::WebGPUIdentifier identifier)
    void CreateRenderBundleEncoder(CyberKit::WebGPU::RenderBundleEncoderDescriptor descriptor, CyberKit::WebGPUIdentifier identifier)
    void CreateQuerySet(CyberKit::WebGPU::QuerySetDescriptor descriptor, CyberKit::WebGPUIdentifier identifier)
    void PushErrorScope(PAL::WebGPU::ErrorFilter errorFilter)
    void PopErrorScope() -> (std::optional<CyberKit::WebGPU::Error> error)
    void SetLabel(String label)
}

#endif
