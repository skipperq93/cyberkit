#if ENABLE(GPU_PROCESS)

messages -> RemoteMediaPlayerManagerProxy NotRefCounted {
    CreateMediaPlayer(CyberKit::MediaPlayerPrivateRemoteIdentifier id, enum:uint8_t CyberCore::MediaPlayerEnums::MediaEngineIdentifier remoteEngineIdentifier, struct CyberKit::RemoteMediaPlayerProxyConfiguration proxyConfiguration) -> (struct CyberKit::RemoteMediaPlayerConfiguration playerConfiguration) Synchronous
    DeleteMediaPlayer(CyberKit::MediaPlayerPrivateRemoteIdentifier id)

    GetSupportedTypes(enum:uint8_t CyberCore::MediaPlayerEnums::MediaEngineIdentifier remoteEngineIdentifier) -> (Vector<String> types) Synchronous
    SupportsType(enum:uint8_t CyberCore::MediaPlayerEnums::MediaEngineIdentifier remoteEngineIdentifier, struct CyberCore::MediaEngineSupportParameters type) -> (enum:uint8_t CyberCore::MediaPlayerEnums::SupportsType support) Synchronous
    OriginsInMediaCache(enum:uint8_t CyberCore::MediaPlayerEnums::MediaEngineIdentifier remoteEngineIdentifier, String path) -> (Vector<CyberCore::SecurityOriginData> origins) Synchronous
    ClearMediaCache(enum:uint8_t CyberCore::MediaPlayerEnums::MediaEngineIdentifier remoteEngineIdentifier, String path, WallTime modifiedSince)
    ClearMediaCacheForOrigins(enum:uint8_t CyberCore::MediaPlayerEnums::MediaEngineIdentifier remoteEngineIdentifier, String path, Vector<CyberCore::SecurityOriginData> origins)
    SupportsKeySystem(enum:uint8_t CyberCore::MediaPlayerEnums::MediaEngineIdentifier remoteEngineIdentifier, String keySystem, String mimeType) -> (bool supports) Synchronous

    PrepareForPlayback(CyberKit::MediaPlayerPrivateRemoteIdentifier id, bool privateMode, enum:uint8_t CyberCore::MediaPlayerEnums::Preload preload, bool preservesPitch, bool prepareForRendering)

    Load(CyberKit::MediaPlayerPrivateRemoteIdentifier id, URL url, CyberCore::ContentType contentType, String keySystem) -> (struct CyberKit::RemoteMediaPlayerConfiguration playerConfiguration) Async
    CancelLoad(CyberKit::MediaPlayerPrivateRemoteIdentifier id)

    PrepareToPlay(CyberKit::MediaPlayerPrivateRemoteIdentifier id)

    Play(CyberKit::MediaPlayerPrivateRemoteIdentifier id)
    Pause(CyberKit::MediaPlayerPrivateRemoteIdentifier id)

    SetVolume(CyberKit::MediaPlayerPrivateRemoteIdentifier id, double volume)
    SetMuted(CyberKit::MediaPlayerPrivateRemoteIdentifier id, bool muted)

    Seek(CyberKit::MediaPlayerPrivateRemoteIdentifier id, MediaTime time)
    SeekWithTolerance(CyberKit::MediaPlayerPrivateRemoteIdentifier id, MediaTime time, MediaTime negativeTolerance, MediaTime positiveTolerance)

    SetPreload(CyberKit::MediaPlayerPrivateRemoteIdentifier id, enum:uint8_t CyberCore::MediaPlayerEnums::Preload preload)
    SetPrivateBrowsingMode(CyberKit::MediaPlayerPrivateRemoteIdentifier id, bool privateMode)
    SetPreservesPitch(CyberKit::MediaPlayerPrivateRemoteIdentifier id, bool preservesPitch)
}

#endif
