    std::unique_ptr<CyberCore::IDBKeyData> m_resultKey;
    std::unique_ptr<CyberCore::IDBGetResult> m_getResult;
    std::unique_ptr<CyberCore::IDBGetAllResult> m_getAllResult;
    uint64_t m_resultInteger;
}

