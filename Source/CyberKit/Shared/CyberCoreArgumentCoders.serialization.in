    CyberCore::IDBKeyPath keyPath()
    bool unique()
    bool multiEntry()
}

class CyberCore::IDBObjectStoreInfo {
    uint64_t identifier()
    String name()
    std::optional<CyberCore::IDBKeyPath> keyPath()
    bool autoIncrement()
