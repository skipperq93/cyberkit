    Vector<String> blobFilePaths()
};

class CyberCore::IDBRequestData {
    CyberCore::IDBConnectionIdentifier m_serverConnectionIdentifier;
    CyberCore::IDBResourceIdentifier m_requestIdentifier;
    std::optional<CyberCore::IDBResourceIdentifier> m_transactionIdentifier;
    std::optional<CyberCore::IDBResourceIdentifier> m_cursorIdentifier;
    uint64_t m_objectStoreIdentifier;
    uint64_t m_indexIdentifier;
    CyberCore::IndexedDB::IndexRecordType m_indexRecordType;
    std::optional<CyberCore::IDBDatabaseIdentifier> m_databaseIdentifier;
    uint64_t m_requestedVersion;
    CyberCore::IndexedDB::RequestType m_requestType;
}

