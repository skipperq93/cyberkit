}

struct CyberCore::IDBIterateCursorData {
    CyberCore::IDBKeyData keyData;
    CyberCore::IDBKeyData primaryKeyData;
    unsigned count;
    CyberCore::IndexedDB::CursorIterateOption option;
}

class CyberCore::IDBResourceIdentifier {
    CyberCore::IDBConnectionIdentifier m_idbConnectionIdentifier
    uint64_t m_resourceNumber
}

class CyberCore::IDBValue {
    CyberCore::ThreadSafeDataBuffer data()
