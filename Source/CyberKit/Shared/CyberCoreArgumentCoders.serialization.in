}

struct CyberCore::IDBKeyRangeData {
    CyberCore::IDBKeyData lowerKey;
    CyberCore::IDBKeyData upperKey;

    bool lowerOpen;
    bool upperOpen;
};

class CyberCore::IDBTransactionInfo {
    CyberCore::IDBResourceIdentifier identifier();
    CyberCore::IDBTransactionMode mode();
    CyberCore::IDBTransactionDurability durability();
    uint64_t newVersion();
    Vector<String> objectStores();
    std::unique_ptr<CyberCore::IDBDatabaseInfo> originalDatabaseInfo();
};

struct CyberCore::IDBGetRecordData {
    CyberCore::IDBKeyRangeData keyRangeData;
    CyberCore::IDBGetRecordDataType type;
}

class CyberCore::IDBIndexInfo {
    uint64_t identifier()
    uint64_t objectStoreIdentifier()
