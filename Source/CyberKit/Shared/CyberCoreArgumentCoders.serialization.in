struct CyberCore::IDBCursorRecord {
    CyberCore::IDBKeyData key;
    CyberCore::IDBKeyData primaryKey;
    CyberCore::IDBValue value;
}

class CyberCore::IDBCursorInfo {
    CyberCore::IDBResourceIdentifier identifier();
    CyberCore::IDBResourceIdentifier transactionIdentifier();
    uint64_t objectStoreIdentifier();
    uint64_t sourceIdentifier();

    CyberCore::IDBKeyRangeData range();

    CyberCore::IndexedDB::CursorSource cursorSource();
    CyberCore::IndexedDB::CursorDirection cursorDirection();
    CyberCore::IndexedDB::CursorType cursorType();
};

class CyberCore::IDBError {
    std::optional<CyberCore::ExceptionCode> code()
    String messageForSerialization()
}

struct CyberCore::IDBGetAllRecordsData {
    CyberCore::IDBKeyRangeData keyRangeData;
    CyberCore::IndexedDB::GetAllType getAllType;
    std::optional<uint32_t> count;
    uint64_t objectStoreIdentifier;
    uint64_t indexIdentifier;
}

class CyberCore::IDBGetResult {
    CyberCore::IDBKeyData keyData()
    CyberCore::IDBKeyData primaryKeyData()
    CyberCore::IDBValue value()
