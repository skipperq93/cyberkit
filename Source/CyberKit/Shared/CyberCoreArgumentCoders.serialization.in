[LegacyPopulateFromEmptyConstructor] class CyberCore::IDBResultData {
    CyberCore::IDBResultType m_type;
    CyberCore::IDBResourceIdentifier m_requestIdentifier;
    CyberCore::IDBError m_error;
    uint64_t m_databaseConnectionIdentifier;
