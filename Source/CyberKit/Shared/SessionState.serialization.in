header: "SessionState.h"
[CustomHeader] struct CyberKit::HTTPBody {
    String contentType;
    Vector<CyberKit::HTTPBody::Element> elements;
};

[Nested] struct CyberKit::HTTPBody::Element {
    std::variant<Vector<uint8_t>, CyberKit::HTTPBody::Element::FileData, String> data;
};

[Nested] struct CyberKit::HTTPBody::Element::FileData {
    String filePath;
    int64_t fileStart;
    std::optional<int64_t> fileLength;
    std::optional<WallTime> expectedFileModificationTime;
};

[CustomHeader, LegacyPopulateFromEmptyConstructor] class CyberKit::FrameState {
    String urlString;
    String originalURLString;
    String referrer;
    AtomString target;

    std::optional<Vector<uint8_t>> stateObjectData;

    int64_t documentSequenceNumber;
    int64_t itemSequenceNumber;

    CyberCore::IntPoint scrollPosition;
    bool shouldRestoreScrollPosition;
    float pageScaleFactor;

    std::optional<CyberKit::HTTPBody> httpBody;

#if PLATFORM(IOS_FAMILY)
    CyberCore::FloatRect exposedContentRect;
    CyberCore::IntRect unobscuredContentRect;
    CyberCore::FloatSize minimumLayoutSizeInScrollViewCoordinates;
    CyberCore::IntSize contentSize;
    bool scaleIsInitial;
    CyberCore::FloatBoxExtent obscuredInsets;
#endif

    Vector<CyberKit::FrameState> children;
    [Validator='CyberKit::FrameState::validateDocumentState(*m_documentState)'] Vector<AtomString> m_documentState;
};

[CustomHeader] struct CyberKit::PageState {
    String title;
    CyberKit::FrameState mainFrameState;
    CyberCore::ShouldOpenExternalURLsPolicy shouldOpenExternalURLsPolicy;
    RefPtr<CyberCore::SerializedScriptValue> sessionStateObject;
    bool wasCreatedByJSWithoutUserInteraction;
};

[CustomHeader] struct CyberKit::BackForwardListItemState {
    CyberCore::BackForwardItemIdentifier identifier;

    CyberKit::PageState pageState;
    bool hasCachedPage;
#if PLATFORM(COCOA) || PLATFORM(GTK)
    [NotSerialized] RefPtr<CyberKit::ViewSnapshot> snapshot;
#endif
};

[CustomHeader] struct CyberKit::BackForwardListState {
    Vector<CyberKit::BackForwardListItemState> items;
    std::optional<uint32_t> currentIndex;
};
