headers: <CyberCore/DisplayListItems.h>

[CustomHeader, AdditionalEncoder=StreamConnectionEncoder] class CyberCore::DisplayList::SetState {
    CyberCore::GraphicsContextState state();
};

[CustomHeader, AdditionalEncoder=StreamConnectionEncoder] class CyberCore::DisplayList::SetLineDash {
    CyberCore::DashArray dashArray();
    float dashOffset();
};

[CustomHeader, AdditionalEncoder=StreamConnectionEncoder] class CyberCore::DisplayList::ClipOutToPath {
    CyberCore::Path path();
};

[CustomHeader, AdditionalEncoder=StreamConnectionEncoder] class CyberCore::DisplayList::ClipPath {
    CyberCore::Path path();
    CyberCore::WindRule windRule();
};

[CustomHeader, AdditionalEncoder=StreamConnectionEncoder] class CyberCore::DisplayList::DrawGlyphs {
    CyberCore::RenderingResourceIdentifier fontIdentifier();
    CyberCore::PositionedGlyphs positionedGlyphs();
};

[CustomHeader, AdditionalEncoder=StreamConnectionEncoder] class CyberCore::DisplayList::DrawSystemImage {
    Ref<CyberCore::SystemImage> systemImage();
    CyberCore::FloatRect destinationRect();
};

[CustomHeader, AdditionalEncoder=StreamConnectionEncoder] class CyberCore::DisplayList::DrawLinesForText {
    CyberCore::FloatPoint blockLocation();
    CyberCore::FloatSize localAnchor();
    CyberCore::DashArray widths();
    float thickness();
    bool isPrinting();
    bool doubleLines();
    CyberCore::StrokeStyle style();
};

[CustomHeader, AdditionalEncoder=StreamConnectionEncoder] class CyberCore::DisplayList::DrawPath {
    CyberCore::Path path();
};

[CustomHeader, AdditionalEncoder=StreamConnectionEncoder] class CyberCore::DisplayList::DrawFocusRingPath {
    CyberCore::Path path();
    float outlineWidth();
    CyberCore::Color color();
};

[CustomHeader, AdditionalEncoder=StreamConnectionEncoder] class CyberCore::DisplayList::DrawFocusRingRects {
    Vector<CyberCore::FloatRect> rects();
    float outlineOffset();
    float outlineWidth();
    CyberCore::Color color();
};

[CustomHeader, AdditionalEncoder=StreamConnectionEncoder] class CyberCore::DisplayList::FillRectWithColor {
    CyberCore::FloatRect rect();
    CyberCore::Color color();
};

[CustomHeader, AdditionalEncoder=StreamConnectionEncoder] class CyberCore::DisplayList::FillRectWithGradient {
    CyberCore::FloatRect rect();
    Ref<CyberCore::Gradient> gradient();
};

[CustomHeader, AdditionalEncoder=StreamConnectionEncoder] class CyberCore::DisplayList::FillCompositedRect {
    CyberCore::FloatRect rect();
    CyberCore::Color color();
    CyberCore::CompositeOperator compositeOperator();
    CyberCore::BlendMode blendMode();
};

[CustomHeader] class CyberCore::DisplayList::FillRoundedRect {
    CyberCore::FloatRoundedRect roundedRect();
    CyberCore::Color color();
    CyberCore::BlendMode blendMode();
};

[CustomHeader] class CyberCore::DisplayList::FillRectWithRoundedHole {
    CyberCore::FloatRect rect();
    CyberCore::FloatRoundedRect roundedHoleRect();
    CyberCore::Color color();
};

[CustomHeader] class CyberCore::DisplayList::FillPath {
    CyberCore::Path path();
};

[CustomHeader] class CyberCore::DisplayList::StrokePath {
    CyberCore::Path path();
};
