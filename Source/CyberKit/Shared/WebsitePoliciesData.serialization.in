enum class CyberKit::WebsiteMetaViewportPolicy : uint8_t {
    Default,
    Respect,
    Ignore,
};

enum class CyberKit::WebsiteMediaSourcePolicy : uint8_t {
    Default,
    Disable,
    Enable
};

enum class CyberKit::WebsiteSimulatedMouseEventsDispatchPolicy : uint8_t {
    Default,
    Allow,
    Deny,
};

enum class CyberKit::WebsiteLegacyOverflowScrollingTouchPolicy : uint8_t {
    Default,
    Disable,
    Enable
};

struct CyberKit::WebsitePoliciesData {
    CyberCore::ContentExtensionEnablement contentExtensionEnablement;
    HashMap<WTF::String, Vector<WTF::String>> activeContentRuleListActionPatterns;
    OptionSet<CyberKit::WebsiteAutoplayQuirk> allowedAutoplayQuirks;
    CyberKit::WebsiteAutoplayPolicy autoplayPolicy;
#if ENABLE(DEVICE_ORIENTATION)
    CyberCore::DeviceOrientationOrMotionPermissionState deviceOrientationAndMotionAccessState;
#endif
    Vector<CyberCore::CustomHeaderFields> customHeaderFields;
    CyberKit::WebsitePopUpPolicy popUpPolicy;
    String customUserAgent;
    String customUserAgentAsSiteSpecificQuirks;
    String customNavigatorPlatform;
    CyberKit::WebsiteMetaViewportPolicy metaViewportPolicy;
    CyberKit::WebsiteMediaSourcePolicy mediaSourcePolicy;
    CyberKit::WebsiteSimulatedMouseEventsDispatchPolicy simulatedMouseEventsDispatchPolicy;
    CyberKit::WebsiteLegacyOverflowScrollingTouchPolicy legacyOverflowScrollingTouchPolicy;
    bool allowContentChangeObserverQuirk;
    CyberCore::AllowsContentJavaScript allowsContentJavaScript;
    CyberCore::MouseEventPolicy mouseEventPolicy;
    CyberCore::ModalContainerObservationPolicy modalContainerObservationPolicy;
    CyberCore::ColorSchemePreference colorSchemePreference;
    OptionSet<CyberCore::NetworkConnectionIntegrity> networkConnectionIntegrityPolicy;
    bool idempotentModeAutosizingOnlyHonorsPercentages;
    bool allowPrivacyProxy;
};
