struct CyberKit::EditorState {
    CyberKit::EditorStateIdentifier identifier;
    bool shouldIgnoreSelectionChanges;
    bool selectionIsNone;
    bool selectionIsRange;
    bool selectionIsRangeInsideImageOverlay;
    bool selectionIsRangeInAutoFilledAndViewableField;
    bool isContentEditable;
    bool isContentRichlyEditable;
    bool isInPasswordField;
    bool isInPlugin;
    bool hasComposition;
    bool triggeredByAccessibilitySelectionChange;
#if PLATFORM(MAC)
    bool canEnableAutomaticSpellingCorrection;
#endif
    std::optional<CyberKit::EditorState::PostLayoutData> postLayoutData;
    std::optional<CyberKit::EditorState::VisualData> visualData;
};

[Nested] struct CyberKit::EditorState::PostLayoutData {
    uint32_t typingAttributes;
#if PLATFORM(COCOA)
    uint64_t selectedTextLength;
    uint32_t textAlignment;
    CyberCore::Color textColor;
    uint32_t enclosingListType;
    CyberCore::WritingDirection baseWritingDirection;
    bool editableRootIsTransparentOrFullyClipped;
#endif
#if PLATFORM(IOS_FAMILY)
    String markedText;
    String wordAtSelection;
    UChar32 characterAfterSelection;
    UChar32 characterBeforeSelection;
    UChar32 twoCharacterBeforeSelection;
#endif
#if PLATFORM(IOS_FAMILY) && USE(DICTATION_ALTERNATIVES)
    Vector<CyberCore::DictationContext> dictationContextsForSelection;
#endif
#if PLATFORM(IOS_FAMILY)
    bool isReplaceAllowed;
    bool hasContent;
    bool isStableStateUpdate;
    bool insideFixedPosition;
    bool hasPlainText;
    CyberCore::Color caretColor;
    bool atStartOfSentence;
    bool selectionStartIsAtParagraphBoundary;
    bool selectionEndIsAtParagraphBoundary;
    std::optional<CyberCore::ElementContext> selectedEditableImage;
#endif
#if PLATFORM(MAC)
    CyberCore::IntRect selectionBoundingRect;
    uint64_t candidateRequestStartPosition;
    String paragraphContextForCandidateRequest;
    String stringForCandidateRequest;
#endif
#if PLATFORM(GTK) || PLATFORM(WPE)
    String surroundingContext;
    uint64_t surroundingContextCursorPosition;
    uint64_t surroundingContextSelectionPosition;
#endif
    std::optional<CyberCore::FontAttributes> fontAttributes;
    bool canCut;
    bool canCopy;
    bool canPaste;
};

[Nested] struct CyberKit::EditorState::VisualData {
#if PLATFORM(IOS_FAMILY) || PLATFORM(GTK) || PLATFORM(WPE)
    CyberCore::IntRect caretRectAtStart;
#endif
#if PLATFORM(IOS_FAMILY)
    CyberCore::IntRect selectionClipRect;
    CyberCore::IntRect caretRectAtEnd;
    Vector<CyberCore::SelectionGeometry> selectionGeometries;
    Vector<CyberCore::SelectionGeometry> markedTextRects;
    CyberCore::IntRect markedTextCaretRectAtStart;
    CyberCore::IntRect markedTextCaretRectAtEnd;
#endif
};
