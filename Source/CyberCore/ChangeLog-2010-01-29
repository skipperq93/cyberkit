        (CyberCore::IndentOutdentCommand::tryIndentingAsListItem): uses appendParagraphIntoNode now
        (CyberCore::IndentOutdentCommand::indentIntoBlockquote): uses appendParagraphIntoNode now
        (CyberCore::IndentOutdentCommand::appendParagraphIntoNode): removes a paragraph and appends it to a new node
