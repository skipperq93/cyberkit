//
//  ProductionProject.xcconfig
//
//  These are Production Configuration project settings for the gtest framework
//  and examples. It is set in the "Based On:" dropdown in the "Project" info
//  dialog.
//  This file is based on the Xcode Configuration files in:
//  http://code.google.com/p/google-toolbox-for-mac/
// 

#include "ReleaseProject.xcconfig"

ARCHS = $(ARCHS$(WK_IOS_11));
ARCHS_IOS_BEFORE_11 = $(ARCHS_STANDARD_32_64_BIT);
ARCHS_IOS_SINCE_11 = $(ARCHS_STANDARD);
ONLY_ACTIVE_ARCH = NO

SDKROOT = $(SDKROOT_$(USE_INTERNAL_SDK));
SDKROOT_ = macosx;
SDKROOT_YES = macosx.internal;
