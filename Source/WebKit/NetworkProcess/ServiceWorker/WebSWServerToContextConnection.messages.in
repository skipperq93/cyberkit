#if ENABLE(SERVICE_WORKER)

messages -> WebSWServerToContextConnection NotRefCounted {
    # When possible, these messages can be implemented directly by CyberCore::SWServerToContextConnection

    ScriptContextFailedToStart(std::optional<CyberCore::ServiceWorkerJobDataIdentifier> jobDataIdentifier, CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, String message)
    ScriptContextStarted(std::optional<CyberCore::ServiceWorkerJobDataIdentifier> jobDataIdentifier, CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, bool doesHandleFetch)
    DidFinishInstall(std::optional<CyberCore::ServiceWorkerJobDataIdentifier> jobDataIdentifier, CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, bool wasSuccessful)
    DidFinishActivation(CyberCore::ServiceWorkerIdentifier identifier)
    SetServiceWorkerHasPendingEvents(CyberCore::ServiceWorkerIdentifier identifier, bool hasPendingEvents)
    SkipWaiting(uint64_t matchAllRequestIdentifier, CyberCore::ServiceWorkerIdentifier identifier)
    WorkerTerminated(CyberCore::ServiceWorkerIdentifier identifier)
    FindClientByVisibleIdentifier(CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, String clientIdentifier) -> (std::optional<CyberCore::ServiceWorkerClientData> data)
    MatchAll(uint64_t matchAllRequestIdentifier, CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, struct CyberCore::ServiceWorkerClientQueryOptions options);
    Claim(CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier) -> (std::optional<CyberCore::ExceptionData> result)
    Focus(CyberCore::ScriptExecutionContextIdentifier serviceWorkerClientIdentifier) -> (std::optional<CyberCore::ServiceWorkerClientData> result)
    Navigate(CyberCore::ScriptExecutionContextIdentifier clientIdentifier, CyberCore::ServiceWorkerIdentifier serviceWorkerIdentifier, URL url) -> (Expected<std::optional<CyberCore::ServiceWorkerClientData>, CyberCore::ExceptionData> result)
    SetScriptResource(CyberCore::ServiceWorkerIdentifier identifier, URL scriptURL, struct CyberCore::ServiceWorkerImportedScript script)
    PostMessageToServiceWorkerClient(CyberCore::ScriptExecutionContextIdentifier destination, struct CyberCore::MessageWithMessagePorts message, CyberCore::ServiceWorkerIdentifier source, String sourceOrigin)
    DidFailHeartBeatCheck(CyberCore::ServiceWorkerIdentifier identifier)
    SetAsInspected(CyberCore::ServiceWorkerIdentifier identifier, bool isInspected)

    OpenWindow(CyberCore::ServiceWorkerIdentifier identifier, URL url) -> (Expected<std::optional<CyberCore::ServiceWorkerClientData>, CyberCore::ExceptionData> newClientData)
}

#endif // ENABLE(SERVICE_WORKER)
