#if PLATFORM(IOS_FAMILY) || (PLATFORM(MAC) && ENABLE(VIDEO_PRESENTATION_MODE))
messages -> PlaybackSessionManager {
    Play(CyberKit::PlaybackSessionContextIdentifier contextId)
    Pause(CyberKit::PlaybackSessionContextIdentifier contextId)
    TogglePlayState(CyberKit::PlaybackSessionContextIdentifier contextId)
    BeginScrubbing(CyberKit::PlaybackSessionContextIdentifier contextId)
    EndScrubbing(CyberKit::PlaybackSessionContextIdentifier contextId)
    SeekToTime(CyberKit::PlaybackSessionContextIdentifier contextId, double time, double toleranceBefore, double toleranceAfter)
    FastSeek(CyberKit::PlaybackSessionContextIdentifier contextId, double time)
    BeginScanningForward(CyberKit::PlaybackSessionContextIdentifier contextId)
    BeginScanningBackward(CyberKit::PlaybackSessionContextIdentifier contextId)
    EndScanning(CyberKit::PlaybackSessionContextIdentifier contextId)
    SetDefaultPlaybackRate(CyberKit::PlaybackSessionContextIdentifier contextId, float defaultPlaybackRate)
    SetPlaybackRate(CyberKit::PlaybackSessionContextIdentifier contextId, float playbackRate)
    SelectAudioMediaOption(CyberKit::PlaybackSessionContextIdentifier contextId, uint64_t index)
    SelectLegibleMediaOption(CyberKit::PlaybackSessionContextIdentifier contextId, uint64_t index)
    HandleControlledElementIDRequest(CyberKit::PlaybackSessionContextIdentifier contextId)
    TogglePictureInPicture(CyberKit::PlaybackSessionContextIdentifier contextId)
    ToggleMuted(CyberKit::PlaybackSessionContextIdentifier contextId)
    SetMuted(CyberKit::PlaybackSessionContextIdentifier contextId, bool muted)
    SetVolume(CyberKit::PlaybackSessionContextIdentifier contextId, double volume)
    SetPlayingOnSecondScreen(CyberKit::PlaybackSessionContextIdentifier contextId, bool value)
    SendRemoteCommand(CyberKit::PlaybackSessionContextIdentifier contextId, enum:uint8_t CyberCore::PlatformMediaSession::RemoteControlCommandType type, struct CyberCore::PlatformMediaSession::RemoteCommandArgument argument)
}
#endif
