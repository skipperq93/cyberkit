[pull]
        rebase = true
[webkitscmpy]
        pull-request = append
        history = disabled
        update-fork = true
        auto-check = true
[webkitscmpy "remotes.origin"]
        url = git@github.com:CyberKit/CyberKit.git
        security-level = 0
        secrets-scanning = true
[webkitscmpy "remotes.security"]
        url = git@github.com:CyberKit/CyberKit-security.git
        security-level = 1
        secrets-scanning = false
[webkitscmpy "remotes.apple"]
        url = git@github.com.matthewbenedict.CyberKit.git
        security-level = 2
        secrets-scanning = false
[webkitscmpy "access"]
        apple = apple/teams/CyberKit
        security = CyberKit/teams/security
[webkitscmpy "pre-pr"]
        style-checker = python3 Tools/Scripts/check-webkit-style
